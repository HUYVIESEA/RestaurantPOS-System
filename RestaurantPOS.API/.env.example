# Database
ConnectionStrings__DefaultConnection=Host=localhost;Database=RestaurantPOS;Username=postgres;Password=YOUR_PASSWORD;Pooling=true;Minimum Pool Size=10;Maximum Pool Size=100;Connection Idle Lifetime=30;

# Redis (optional - falls back to memory cache if not set)
ConnectionStrings__RedisConnection=localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000

# JWT Authentication (REQUIRED)
JwtSettings__SecretKey=YOUR_64_CHAR_SECRET_KEY_HERE
JwtSettings__Issuer=RestaurantPOS.API
JwtSettings__Audience=RestaurantPOS.Client
JwtSettings__ExpiryInHours=24

# Email Settings
EmailSettings__SmtpUser=your-email@gmail.com
EmailSettings__SmtpPassword=YOUR_GMAIL_APP_PASSWORD

# Payment Gateway
Vnpay__TmnCode=YOUR_VNPAY_TMN_CODE
Vnpay__HashSecret=YOUR_VNPAY_HASH_SECRET

# Activation Key
SourceCode__ActivationKey=HUYVESEA-2026-POS-SYSTEM
