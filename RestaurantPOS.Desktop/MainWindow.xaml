<Window x:Class="RestaurantPOS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantPOS.Desktop"
        xmlns:views="clr-namespace:RestaurantPOS.Desktop.Views"
        xmlns:vm="clr-namespace:RestaurantPOS.Desktop.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="Restaurant POS - KiotViet Style" 
        Icon="Res/icon/restaurant.ico"
        WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <materialDesign:DialogHost Identifier="RootDialog">
        <materialDesign:DrawerHost x:Name="MainDrawerHost" OpenMode="Modal">
        <!-- Drawer Content (Navigation) -->
        <materialDesign:DrawerHost.LeftDrawerContent>
            <Border Background="White" Width="250">
                <StackPanel Margin="0">
                    <!-- Drawer Header -->
                    <Grid Height="150" Background="{DynamicResource PrimaryHueMidBrush}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                             <Image Source="pack://application:,,,/Res/icon/restaurant.ico" Height="60" Width="60" Margin="0,0,0,10"/>
                             <TextBlock Text="POS SYSTEM" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Menu Items -->
                    <StackPanel Margin="0,10">
                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Height="50"
                                     Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                                     IsChecked="{Binding IsDashboardView, Mode=OneWay}"
                                     Click="MenuButton_Click"
                                     HorizontalContentAlignment="Left" Padding="20,0"
                                     BorderBrush="Transparent" Margin="10,5">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="TachometerAlt" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,20,0"/>
                                <TextBlock Text="Tổng quan" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Height="50"
                                     Command="{Binding NavigateCommand}" CommandParameter="Sales"
                                     IsChecked="{Binding IsSalesView, Mode=OneWay}"
                                     Click="MenuButton_Click"
                                     HorizontalContentAlignment="Left" Padding="20,0"
                                     BorderBrush="Transparent" Margin="10,5">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="CashRegister" Width="24" Height="24" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,20,0"/>
                                <TextBlock Text="Bán hàng" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        
                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Height="50"
                                     Command="{Binding NavigateCommand}" CommandParameter="Orders"
                                     IsChecked="{Binding IsOrdersView, Mode=OneWay}"
                                     Click="MenuButton_Click"
                                     HorizontalContentAlignment="Left" Padding="20,0"
                                     BorderBrush="Transparent" Margin="10,5">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ListAlt" Width="24" Height="24" Foreground="Gray" Margin="0,0,20,0"/>
                                <TextBlock Text="Đơn hàng" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Height="50"
                                     Command="{Binding NavigateCommand}" CommandParameter="Products"
                                     IsChecked="{Binding IsProductsView, Mode=OneWay}"
                                     Click="MenuButton_Click"
                                     HorizontalContentAlignment="Left" Padding="20,0"
                                     BorderBrush="Transparent" Margin="10,5">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="BoxOpen" Width="24" Height="24" Foreground="Gray" Margin="0,0,20,0"/>
                                <TextBlock Text="Hàng hóa" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Height="50"
                                     Command="{Binding NavigateCommand}" CommandParameter="Reports"
                                     IsChecked="{Binding IsReportsView, Mode=OneWay}"
                                     Click="MenuButton_Click"
                                     Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     HorizontalContentAlignment="Left" Padding="20,0"
                                     BorderBrush="Transparent" Margin="10,5">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ChartLine" Width="24" Height="24" Foreground="Gray" Margin="0,0,20,0"/>
                                <TextBlock Text="Báo cáo" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Height="50"
                                     Command="{Binding NavigateCommand}" CommandParameter="Settings"
                                     IsChecked="{Binding IsSettingsView, Mode=OneWay}"
                                     Click="MenuButton_Click"
                                     Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     HorizontalContentAlignment="Left" Padding="20,0"
                                     BorderBrush="Transparent" Margin="10,5">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Cog" Width="24" Height="24" Foreground="Gray" Margin="0,0,20,0"/>
                                <TextBlock Text="Cài đặt" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>
            </Border>
        </materialDesign:DrawerHost.LeftDrawerContent>

        <!-- Main Content -->
        <Grid Background="#F0F2F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/> <!-- Header -->
                <RowDefinition Height="*"/>  <!-- Content -->
            </Grid.RowDefinitions>

            <!-- KiotViet Style Header -->
            <Grid Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Logo/Menu -->
                    <ColumnDefinition Width="*"/>    <!-- Search -->
                    <ColumnDefinition Width="Auto"/> <!-- Actions -->
                </Grid.ColumnDefinitions>

                <!-- Logo & Menu -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Button Style="{StaticResource MaterialDesignIconButton}" Foreground="White" Margin="0,0,15,0"
                            Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}"
                            CommandParameter="{x:Static Dock.Left}">
                        <fa:IconImage Icon="Bars" Foreground="White" Height="20" Width="20"/>
                    </Button>
                    <Image Source="pack://application:,,,/Res/icon/restaurant.ico" Height="30" Width="30" Margin="0,0,10,0"/>
                    <TextBlock Text="POS System" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Search & Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <!-- Sales View Actions (Back & Table Info) -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsSalesView, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- Back Button (Visible in POS Mode) -->
                        <Button Style="{StaticResource MaterialDesignIconButton}" 
                                Command="{Binding BackToTablesCommand}"
                                Visibility="{Binding IsTableSelectionMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                ToolTip="Trở về danh sách bàn"
                                Foreground="White" Margin="0,0,10,0">
                            <fa:IconImage Icon="ArrowLeft" Foreground="White" Height="20" Width="20"/>
                        </Button>

                        <!-- Table Info (Visible in POS Mode) -->
                        <Border Background="#30FFFFFF" CornerRadius="5" Padding="10,5" Margin="0,0,20,0"
                                Visibility="{Binding IsTableSelectionMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedTable.TableNumber, StringFormat='Bàn: {0}'}" 
                                       Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Search Bar -->
                    <Border Background="White" CornerRadius="5" Height="36" Width="400">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="Search" Foreground="Gray" Height="14" Width="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Tìm kiếm mặt hàng, bàn..." 
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" VerticalAlignment="Center" FontSize="14"
                                     Padding="0,0,10,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Right Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <!-- User Profile -->
                    <Border Background="#30FFFFFF" CornerRadius="20" Padding="5,2,15,2" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="16" Background="White" Margin="0,0,10,0">
                                 <TextBlock Text="{Binding CurrentUserName, Converter={StaticResource SubstringConverter}, ConverterParameter=1}" 
                                           Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding CurrentUserName}" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="NotificationButton" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Thông báo" Foreground="White"
                            Command="{Binding ToggleNotificationsCommand}">
                        <Grid>
                            <fa:IconImage Icon="Bell" Foreground="White" Height="20" Width="20"/>
                            <Border Background="Red" CornerRadius="7" Width="14" Height="14" 
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-5,-5,0,0"
                                    Visibility="{Binding Notifications.Count, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding Notifications.Count}" Foreground="White" FontSize="9" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Button>
                    
                    <Popup PlacementTarget="{Binding ElementName=NotificationButton}" 
                           Placement="Bottom" 
                           IsOpen="{Binding IsNotificationsOpen, Mode=TwoWay}" 
                           StaysOpen="False"
                           AllowsTransparency="True" 
                           PopupAnimation="Slide">
                        <Border Background="White" Width="350" MaxHeight="400" CornerRadius="5" BorderBrush="#EEE" BorderThickness="1" Margin="0,5,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Padding="15,10" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Thông báo" FontWeight="Bold" FontSize="16"/>
                                </Border>
                                
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                                    <ItemsControl ItemsSource="{Binding Notifications}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="15,10" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <fa:IconImage Icon="InfoCircle" Foreground="{DynamicResource PrimaryHueMidBrush}" Height="16" Width="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                                                        
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="14"/>
                                                            <TextBlock Text="{Binding TimeAgo}" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <TextBlock Grid.Row="1" Text="Không có thông báo nào" Foreground="Gray" HorizontalAlignment="Center" Margin="20"
                                           Visibility="{Binding Notifications.Count, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>
                    </Popup>
                    
                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Đăng xuất" 
                            Command="{Binding LogoutCommand}" Foreground="White">
                        <fa:IconImage Icon="SignOutAlt" Foreground="White" Height="20" Width="20"/>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignIconButton}" ToolTip="Thoát"
                            Command="{Binding CloseApplicationCommand}" Foreground="White">
                        <fa:IconImage Icon="Times" Foreground="White" Height="20" Width="20"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Layout (Content Only) -->
            <Grid Grid.Row="1">
                <!-- Snackbar for Toast Notifications -->
                <materialDesign:Snackbar MessageQueue="{Binding MessageQueue}" Panel.ZIndex="1000" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                <!-- SALES VIEW -->
                <Grid Visibility="{Binding IsSalesView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <!-- TABLE SELECTION SCREEN -->
                    <Grid Visibility="{Binding IsTableSelectionMode, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header Actions -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0"
                                        Command="{Binding ToggleMergeModeCommand}"
                                        Content="{Binding IsMergeMode, Converter={StaticResource BooleanToContentConverter}, ConverterParameter='Ghép bàn|Hủy ghép'}"/>
                                
                                <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Command="{Binding ConfirmMergeCommand}"
                                        Content="Xác nhận ghép"
                                        Visibility="{Binding IsMergeMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Table Filters -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <ComboBox ItemsSource="{Binding AvailableFloors}" 
                                              SelectedItem="{Binding SelectedFloorFilter}"
                                              materialDesign:HintAssist.Hint="Khu vực"
                                              Style="{StaticResource MaterialDesignFilledComboBox}"
                                              Width="150" Margin="0,0,20,0" VerticalAlignment="Center"/>

                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipPrimaryRadioButton}" IsChecked="True" Content="Tất cả" Margin="0,0,10,0" 
                                                 Command="{Binding FilterTableCommand}" CommandParameter="All"/>
                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Content="Trống" Margin="0,0,10,0" 
                                                 Command="{Binding FilterTableCommand}" CommandParameter="Available"/>
                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Content="Có người" Margin="0,0,10,0" 
                                                 Command="{Binding FilterTableCommand}" CommandParameter="Occupied"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding TablesView}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Width="150" Height="160" Margin="10" Padding="0"
                                                Command="{Binding DataContext.SelectTableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:Card UniformCornerRadius="10" Width="150" Height="160">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- Table Icon/Status -->
                                                    <Grid Grid.Row="0" Background="{Binding StatusColor}">
                                                        <fa:IconImage Icon="Chair" Foreground="White" Height="50" Width="50" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,15"/>
                                                        <TextBlock Text="{Binding TableNumber}" Foreground="White" FontSize="24" FontWeight="Bold" 
                                                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"/>
                                                        
                                                        <!-- Duration Timer (Overlay) -->
                                                        <Border Background="#40000000" CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10" Padding="10,4"
                                                                Visibility="{Binding HasDuration, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <fa:IconImage Icon="Clock" Foreground="White" Height="12" Width="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Duration}" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Merge Selection Indicator -->
                                                        <CheckBox IsChecked="{Binding IsSelectedForMerge, Mode=OneWay}" 
                                                                  Style="{StaticResource MaterialDesignAccentCheckBox}"
                                                                  HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                                                  Visibility="{Binding DataContext.IsMergeMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <CheckBox.LayoutTransform>
                                                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                                            </CheckBox.LayoutTransform>
                                                        </CheckBox>
                                                    </Grid>
                                                    
                                                    <!-- Footer Info -->
                                                    <Border Grid.Row="1" Background="White" BorderBrush="#EEE" BorderThickness="0,1,0,0" Height="45">
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayStatus}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
                                                            <TextBlock Text="{Binding MergedTableNumbers, StringFormat='(Ghép: {0})'}" 
                                                                       HorizontalAlignment="Center" FontSize="11" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="Bold"
                                                                       Visibility="{Binding IsMerged, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </materialDesign:Card>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- POS CONTENT (Product Selection) -->
                    <Grid Margin="20" Visibility="{Binding IsTableSelectionMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <!-- Product Grid Section -->
                        <Grid Grid.Column="0" Margin="0,0,20,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Categories -->
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipPrimaryRadioButton}" IsChecked="True" Content="Tất cả" Margin="0,0,10,0" Command="{Binding FilterCategoryCommand}" CommandParameter="All"/>
                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Content="Đồ ăn" Margin="0,0,10,0" Command="{Binding FilterCategoryCommand}" CommandParameter="Food"/>
                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Content="Đồ uống" Margin="0,0,10,0" Command="{Binding FilterCategoryCommand}" CommandParameter="Drinks"/>
                                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}" Content="Khác" Margin="0,0,10,0" Command="{Binding FilterCategoryCommand}" CommandParameter="Other"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Products -->
                            <Grid Grid.Row="1">
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Value="0" IsIndeterminate="True"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Width="50" Height="50"/>
                                
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding ProductsView}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <materialDesign:Card Width="200" Height="240" Margin="0,0,20,20" UniformCornerRadius="10">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="140"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Background="#EEE" CornerRadius="10,10,0,0">
                                                            <fa:IconImage Icon="{Binding ImageUrl}" Foreground="Gray" Height="60" Width="60" Opacity="0.5"/>
                                                        </Border>
                                                        <StackPanel Grid.Row="1" Margin="15">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} đ}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="Bold" Margin="0,5,0,0"/>
                                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="30" Margin="0,10,0,0"
                                                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="Thêm" FontSize="12"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </materialDesign:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <!-- Order Panel (Bill) -->
                        <materialDesign:Card Grid.Column="1" Background="White" UniformCornerRadius="10" VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="60"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Bill Header -->
                                <Border Grid.Row="0" BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="20,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Hóa đơn" FontWeight="Bold" FontSize="18"/>
                                            <Border Background="#E0F2F1" CornerRadius="5" Margin="10,0,0,0" Padding="8,2">
                                                <TextBlock Text="{Binding SelectedTable.TableNumber}" Foreground="{DynamicResource PrimaryHueMidBrush}" FontSize="12" FontWeight="Bold"/>
                                            </Border>
                                            
                                            <!-- Split Table Button -->
                                            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="24" Margin="10,0,0,0" Padding="10,0"
                                                    Command="{Binding SplitTableCommand}"
                                                    Visibility="{Binding SelectedTable.IsMerged, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    BorderBrush="#F44336" Foreground="#F44336">
                                                <TextBlock Text="Tách bàn" FontSize="10"/>
                                            </Button>
                                        </StackPanel>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" HorizontalAlignment="Right" ToolTip="Clear All"
                                                Command="{Binding ClearCartCommand}">
                                            <fa:IconImage Icon="TrashAlt" Foreground="Red" Height="16" Width="16"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Bill Items -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,10">
                                    <ItemsControl ItemsSource="{Binding CartItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Grid Margin="20,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Product.Name}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Product.Price, StringFormat={}{0:N0} đ}" FontSize="12" Foreground="Gray"/>
                                                            
                                                            <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                                     materialDesign:HintAssist.Hint="Ghi chú..."
                                                                     FontSize="11" FontStyle="Italic" 
                                                                     Margin="0,2,0,5" BorderThickness="0,0,0,1" Padding="0"/>

                                                            <Border Background="#E8F5E9" CornerRadius="3" HorizontalAlignment="Left" Padding="5,2" Margin="0,2,0,0"
                                                                    Visibility="{Binding IsNew, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                                <TextBlock Text="Đã gọi" FontSize="10" Foreground="#2E7D32"/>
                                                            </Border>
                                                            <Border Background="#FFF3E0" CornerRadius="3" HorizontalAlignment="Left" Padding="5,2" Margin="0,2,0,0"
                                                                    Visibility="{Binding IsNew, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="Mới" FontSize="10" Foreground="#EF6C00" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                                            <Button Style="{StaticResource MaterialDesignIconButton}" Height="24" Width="24"
                                                                    Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <fa:IconImage Icon="Minus" Height="10" Width="10"/>
                                                            </Button>
                                                            
                                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                                                     VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"
                                                                     Width="30" HorizontalContentAlignment="Center"
                                                                     PreviewTextInput="NumberValidationTextBox"/>
                                                            
                                                            <Button Style="{StaticResource MaterialDesignIconButton}" Height="24" Width="24"
                                                                    Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}">
                                                                <fa:IconImage Icon="Plus" Height="10" Width="10"/>
                                                            </Button>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat={}{0:N0}}" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <Separator Background="#EEE" Margin="20,5"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Bill Summary & Actions -->
                                <StackPanel Grid.Row="2" Background="#FAFAFA" Margin="0,10,0,0">
                                    <Grid Margin="20,15,20,5">
                                        <TextBlock Text="Tạm tính" Foreground="Gray"/>
                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid Margin="20,5">
                                        <TextBlock Text="Giảm giá" Foreground="Gray"/>
                                        <TextBlock Text="0 đ" HorizontalAlignment="Right" FontWeight="Bold"/>
                                    </Grid>
                                    <Separator Background="#DDD" Margin="20,10"/>
                                    <Grid Margin="20,5,20,20">
                                        <TextBlock Text="Tổng cộng" FontSize="18" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                    </Grid>
                                    
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="50" Margin="20,0,20,10"
                                            materialDesign:ButtonAssist.CornerRadius="10" FontSize="16"
                                            Command="{Binding SaveOrderCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage Icon="Save" Foreground="{DynamicResource PrimaryHueMidBrush}" Height="20" Width="20" Margin="0,0,10,0"/>
                                            <TextBlock Text="Lưu đơn"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Height="50" Margin="20,0,20,20"
                                            materialDesign:ButtonAssist.CornerRadius="10" FontSize="16"
                                            Command="{Binding CheckoutCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconImage Icon="CreditCard" Foreground="White" Height="20" Width="20" Margin="0,0,10,0"/>
                                            <TextBlock Text="Thanh toán"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>

                <!-- OTHER VIEWS -->
                <views:OrdersView Visibility="{Binding IsOrdersView, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Grid Visibility="{Binding IsProductsView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <views:ProductsView DataContext="{Binding ProductsVM}"/>
                </Grid>
                <Grid Visibility="{Binding IsReportsView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <views:ReportsView DataContext="{Binding ReportsVM}"/>
                </Grid>
                <Grid Visibility="{Binding IsDashboardView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <views:DashboardView DataContext="{Binding DashboardVM}"/>
                </Grid>
                <Grid Visibility="{Binding IsSettingsView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <views:SettingsView DataContext="{Binding SettingsVM}"/>
                </Grid>
                <Grid Visibility="{Binding IsTableManagementView, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <views:TableManagementView DataContext="{Binding TableManagementVM}"/>
                </Grid>
            </Grid>
        </Grid>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</Window>
