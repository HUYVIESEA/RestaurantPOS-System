<Window x:Class="RestaurantPOS.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantPOS.Desktop"
        xmlns:vm="clr-namespace:RestaurantPOS.Desktop.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        mc:Ignorable="d"
        Title="Smart POS" 
        Icon="Res/icon/restaurant.ico"
        WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <!-- Background with Gradient/Image -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0062CC" Offset="0.0"/>
                <GradientStop Color="#00359B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Centered Login Card -->
        <Border Width="450" Height="600" CornerRadius="10" Background="White" Effect="{StaticResource MaterialDesignShadowDepth3}" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Close Button -->
                <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                        Click="CloseButton_Click" ToolTip="Thoát ứng dụng">
                    <fa:IconImage Icon="Times" Foreground="Gray" Height="20" Width="20"/>
                </Button>

                <!-- Logo & Title -->
                <StackPanel Grid.Row="0" Margin="0,60,0,30" HorizontalAlignment="Center">
                    <Border Background="White" Width="100" Height="100" CornerRadius="50" Margin="0,0,0,20">
                        <Image Source="pack://application:,,,/Res/icon/restaurant.ico" Height="60" Width="60" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="POS SYSTEM" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Đăng nhập hệ thống quản lý" FontSize="16" Foreground="#757575" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Login Form -->
                <StackPanel Grid.Row="1" Margin="50,0">
                    <TextBox materialDesign:HintAssist.Hint="Tên đăng nhập" 
                             AutomationProperties.AutomationId="txtUsername"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Margin="0,0,0,25"
                             materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}"
                             Foreground="Black" CaretBrush="{DynamicResource PrimaryHueMidBrush}">
                        <materialDesign:HintAssist.Foreground>
                            <SolidColorBrush Color="#0062CC"/>
                        </materialDesign:HintAssist.Foreground>
                    </TextBox>

                    <PasswordBox x:Name="txtPassword"
                                 materialDesign:HintAssist.Hint="Mật khẩu"
                                 AutomationProperties.AutomationId="txtPassword"
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 FontSize="16" Margin="0,0,0,10"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}"
                                 Foreground="Black" CaretBrush="{DynamicResource PrimaryHueMidBrush}">
                        <materialDesign:HintAssist.Foreground>
                            <SolidColorBrush Color="#0062CC"/>
                        </materialDesign:HintAssist.Foreground>
                    </PasswordBox>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,10,0,20" HorizontalAlignment="Center"/>

                    <Button Content="ĐĂNG NHẬP" Height="55" Margin="0,10,0,0"
                            AutomationProperties.AutomationId="btnLogin"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            materialDesign:ButtonAssist.CornerRadius="27.5"
                            FontSize="18" FontWeight="Bold"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0" IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Margin="0,30,0,0"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Footer Info -->
        <TextBlock Text="© 2025 Restaurant POS System. All rights reserved." 
                   Foreground="White" Opacity="0.7" 
                   VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>
    </Grid>
</Window>
