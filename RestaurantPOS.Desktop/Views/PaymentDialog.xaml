<Window x:Class="RestaurantPOS.Desktop.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh Toán" 
        Height="550" 
        Width="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">
    
    <Border Background="White" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#673AB7" CornerRadius="12,12,0,0" Padding="25,20">
                <StackPanel>
                    <TextBlock Text="💳 Thanh Toán" 
                               Foreground="White" 
                               FontSize="24" 
                               FontWeight="Bold"/>
                    <TextBlock x:Name="TableNameText"
                               Foreground="White" 
                               FontSize="14" 
                               Opacity="0.9"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25,20">
                    
                    <!-- Total Amount -->
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock Text="Tổng tiền:" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalAmountText" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="#F44336" 
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Payment Method -->
                    <TextBlock Text="Phương thức thanh toán" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <RadioButton x:Name="CashRadio" 
                                 Content="💵 Tiền mặt" 
                                 FontSize="16" 
                                 Margin="0,0,0,15"
                                 IsChecked="True"
                                 Checked="PaymentMethod_Changed"/>
                    
                    <RadioButton x:Name="OtherRadio" 
                                 Content="💳 Phương thức khác" 
                                 FontSize="16"
                                 Margin="0,0,0,15"
                                 Checked="PaymentMethod_Changed"/>
                    
                    <TextBlock x:Name="ComingSoonText"
                               Text="(Coming soon)" 
                               FontSize="12" 
                               Foreground="Gray" 
                               FontStyle="Italic"
                               Margin="30,-10,0,15"
                               Visibility="Collapsed"/>

                    <!-- Cash Payment Section -->
                    <StackPanel x:Name="CashPaymentPanel">
                        <Separator Margin="0,10,0,20"/>
                        
                        <TextBlock Text="Tiền khách đưa" FontSize="14" Margin="0,0,0,5"/>
                        <TextBox x:Name="ReceivedAmountTextBox" 
                                 FontSize="18" 
                                 Padding="12,10"
                                 Text="0"
                                 TextChanged="ReceivedAmount_TextChanged"
                                 PreviewTextInput="NumberOnly_PreviewTextInput"/>

                        <!-- Quick Amount Buttons -->
                        <TextBlock Text="Chọn nhanh:" FontSize="12" Foreground="Gray" Margin="0,10,0,5"/>
                        <WrapPanel Margin="0,0,0,15">
                            <Button Content="50,000" Click="QuickAmount_Click" Margin="0,0,5,5" Padding="10,5" Background="#E3F2FD" BorderThickness="1" BorderBrush="#2196F3"/>
                            <Button Content="100,000" Click="QuickAmount_Click" Margin="0,0,5,5" Padding="10,5" Background="#E3F2FD" BorderThickness="1" BorderBrush="#2196F3"/>
                            <Button Content="200,000" Click="QuickAmount_Click" Margin="0,0,5,5" Padding="10,5" Background="#E3F2FD" BorderThickness="1" BorderBrush="#2196F3"/>
                            <Button Content="500,000" Click="QuickAmount_Click" Margin="0,0,5,5" Padding="10,5" Background="#E3F2FD" BorderThickness="1" BorderBrush="#2196F3"/>
                            <Button Content="Vừa đủ" Click="ExactAmount_Click" Margin="0,0,5,5" Padding="10,5" Background="#C8E6C9" BorderThickness="1" BorderBrush="#4CAF50"/>
                        </WrapPanel>

                        <Separator Margin="0,5,0,15"/>

                        <!-- Change Amount -->
                        <Grid>
                            <TextBlock Text="Tiền thừa:" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ChangeAmountText" 
                                       Text="0 đ"
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="#4CAF50" 
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" BorderBrush="#F5F5F5" BorderThickness="0,1,0,0" Padding="25,15" Background="#FAFAFA" CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Hủy" 
                            Click="Cancel_Click"
                            Height="45"
                            FontSize="16"
                            Background="White"
                            Foreground="#616161"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Margin="0,0,5,0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="1"
                            x:Name="ConfirmButton"
                            Content="💵 Xác Nhận Thanh Toán" 
                            Click="Confirm_Click"
                            Height="45"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="#4CAF50"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="5,0,0,0"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
