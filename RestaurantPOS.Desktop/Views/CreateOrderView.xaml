<UserControl x:Class="RestaurantPOS.Desktop.Views.CreateOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.Desktop.Views"
             xmlns:vm="clr-namespace:RestaurantPOS.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side: Menu Selection -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">

                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#673AB7" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Tạo Đơn Hàng Mới"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddingToExistingOrder}" Value="True">
                                        <Setter Property="Text" Value="Thêm Món Vào Đơn Hiện Tại"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <TextBlock FontSize="14" Foreground="Gray" Margin="45,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Chọn bàn và món ăn"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAddingToExistingOrder}" Value="True">
                                    <Setter Property="Text" Value="Chọn thêm món ăn cho đơn hàng"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Filters -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Table Selection -->
                <ComboBox Grid.Column="0" 
                          ItemsSource="{Binding Tables}" 
                          SelectedItem="{Binding SelectedTable}"
                          DisplayMemberPath="Name"
                          Margin="0,0,10,0"
                          Padding="10"
                          Background="White">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center" Margin="5,0"/>
                                                <TextBlock Grid.Column="1" Text="▼" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                        <Border x:Name="DropDownBorder" Background="White" BorderThickness="1" BorderBrush="#E0E0E0"/>
                                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>

                <!-- Category Selection -->
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding Categories}" 
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          Margin="10,0,0,0"
                          Padding="10"
                          Background="White"/>
            </Grid>

            <!-- Product Grid -->
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}"
                                    Margin="0,0,15,15"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <Border Background="White" CornerRadius="8" Width="180" Height="200">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Image Placeholder -->
                                        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="8,8,0,0">
                                            <TextBlock Text="🍽️" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                                        </Border>

                                        <!-- Info -->
                                        <Border Grid.Row="1" Padding="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap" Height="40"/>
                                                <TextBlock Text="{Binding Price, StringFormat={}{0:N0} đ}" Foreground="#673AB7" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Right Side: Cart -->
        <Border Grid.Column="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Giỏ Hàng" FontSize="20" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Bàn: " Foreground="Gray"/>
                        <TextBlock Text="{Binding SelectedTable.Name, TargetNullValue='Chưa chọn'}" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Cart Items -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F5F5F5" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Item Info -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N0} đ}" FontSize="12" Foreground="Gray"/>
                                        </StackPanel>

                                        <!-- Quantity Controls -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                            <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Content="-" Width="24" Height="24" Background="#EEEEEE" Foreground="Black" BorderThickness="0"/>
                                            <TextBlock Text="{Binding Quantity}" Margin="10,0" VerticalAlignment="Center"/>
                                            <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Content="+" Width="24" Height="24" Background="#EEEEEE" Foreground="Black" BorderThickness="0"/>
                                        </StackPanel>

                                        <!-- Subtotal -->
                                        <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat={}{0:N0} đ}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Tổng cộng" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}" FontSize="18" FontWeight="Bold" Foreground="#673AB7" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Command="{Binding SubmitOrderCommand}" 
                            Background="#673AB7" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="TẠO ĐƠN HÀNG"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAddingToExistingOrder}" Value="True">
                                        <Setter Property="Content" Value="THÊM MÓN VÀO ĐƠN"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Command="{Binding CancelCommand}" 
                            Content="Hủy bỏ" 
                            Background="Transparent" 
                            Foreground="Gray" 
                            Margin="0,10,0,0"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.ColumnSpan="2" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Đang xử lý..." FontSize="16" Margin="0,10,0,0" Foreground="#673AB7"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
