<UserControl x:Class="RestaurantPOS.Desktop.Views.MenuManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:converters="clr-namespace:RestaurantPOS.Desktop.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <Style TargetType="TextBox" x:Key="FormTextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                CornerRadius="4" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0090DA"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Thực đơn" FontSize="20" FontWeight="Bold" Foreground="#1A202C"/>
                    <Border Background="#E2E8F0" CornerRadius="4" Margin="15,0,0,0" Padding="8,4">
                        <TextBlock Text="{Binding Products.Count, StringFormat='{}{0} món'}" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568"/>
                    </Border>
                </StackPanel>

                <!-- Search Box -->
                <Border Grid.Column="1" Margin="40,0" MaxWidth="500" Background="#F7FAFC" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <fa:IconImage Grid.Column="0" Icon="MagnifyingGlass" Width="14" Height="14" Foreground="#A0AEC0" Margin="12,0,8,0"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Padding="0,10"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"
                                 Tag="Tìm kiếm món ăn..."
                                 Style="{StaticResource {x:Type TextBox}}">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type TextBox}">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                               Foreground="#A0AEC0"
                                                               Margin="2,0,0,0"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False"
                                                               Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        
                        <!-- Clear Search Button -->
                        <Button Grid.Column="2"
                                Command="{Binding ClearSearchCommand}"
                                Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0">
                            <fa:IconImage Icon="TimesCircle" Width="14" Height="14" Foreground="#A0AEC0"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding AddProductCommand}"
                            IsEnabled="{Binding SelectedCategory, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="#0090DA" 
                            Foreground="White" 
                            BorderThickness="0"
                            Padding="15,8" 
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Plus" Width="14" Height="14" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock Text="Thêm mới" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/> <!-- Right Panel Column -->
            </Grid.ColumnDefinitions>

            <!-- Categories Sidebar -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="15">
                        <Grid>
                            <TextBlock Text="NHÓM HÀNG" FontSize="13" FontWeight="Bold" Foreground="#718096"/>
                            <Button HorizontalAlignment="Right"
                                    Width="24" Height="24"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Thêm nhóm hàng">
                                <fa:IconImage Icon="PlusCircle" Width="16" Height="16" Foreground="#0090DA"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding FilterCategories}" 
                             SelectedItem="{Binding SelectedCategory}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Padding="0"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" 
                                                    BorderBrush="#E2E8F0" 
                                                    BorderThickness="0,0,0,1" 
                                                    Background="{TemplateBinding Background}" 
                                                    Padding="{TemplateBinding Padding}" 
                                                    SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter Property="Background" TargetName="Bd" Value="#EBF8FF"/>
                                                    <Setter Property="BorderBrush" TargetName="Bd" Value="#0090DA"/>
                                                    <Setter Property="BorderThickness" TargetName="Bd" Value="3,0,0,1"/>
                                                    <Setter Property="Foreground" Value="#0090DA"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter Property="Background" TargetName="Bd" Value="#F7FAFC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button Command="{Binding DataContext.EditCategoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Width="24" Height="24" Margin="0,0,2,0"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <fa:IconImage Icon="Pencil" Width="12" Height="12" Foreground="#718096"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Width="24" Height="24"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <fa:IconImage Icon="Trash" Width="12" Height="12" Foreground="#EF4444"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Products Grid -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Products List -->
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Products}" 
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E2E8F0"
                              VerticalGridLinesBrush="#E2E8F0"
                              Background="White"
                              BorderThickness="0"
                              RowHeight="50"
                              ColumnHeaderHeight="45">
                        
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#4A5568"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" BorderBrush="Transparent" BorderThickness="0" Background="Transparent" SnapsToDevicePixels="True">
                                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EBF8FF"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <!-- Code/ID (Optional, using Image for now) -->
                            <DataGridTemplateColumn Header="Hình ảnh" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="36" Height="36" CornerRadius="4" Background="#F1F5F9" Margin="0">
                                            <fa:IconImage Icon="Image" 
                                                          Width="16" Height="16" 
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"
                                                          Foreground="#CBD5E0"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Name -->
                            <DataGridTemplateColumn Header="Tên hàng" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="#2D3748"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#718096" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Price -->
                            <DataGridTextColumn Header="Giá bán" 
                                                Binding="{Binding Price, StringFormat={}{0:N0}}" 
                                                Width="120">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <!-- Status -->
                            <DataGridTemplateColumn Header="Trạng thái" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#C6F6D5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Background" Value="#FED7D7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Đang bán"/>
                                                        <Setter Property="Foreground" Value="#22543D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="Text" Value="Ngừng bán"/>
                                                                <Setter Property="Foreground" Value="#742A2A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Actions -->
                            <DataGridTemplateColumn Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8">
                                            <Button ToolTip="Sửa"
                                                    Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Width="28" Height="28"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                <fa:IconImage Icon="PenToSquare" Width="14" Height="14" Foreground="#0090DA"/>
                                            </Button>
                                            <Button ToolTip="Xóa"
                                                    Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Width="28" Height="28"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                <fa:IconImage Icon="TrashCan" Width="14" Height="14" Foreground="#E53E3E"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Properties Panel -->
            <Border Grid.Column="2" 
                    Width="350" 
                    Background="White" 
                    BorderBrush="#E2E8F0" 
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding IsRightPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="20,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Border Grid.Row="0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,15">
                        <Grid>
                            <TextBlock Text="{Binding RightPanelTitle}" FontSize="16" FontWeight="Bold" Foreground="#2D3748"/>
                            <Button HorizontalAlignment="Right"
                                    Command="{Binding CloseRightPanelCommand}"
                                    Width="24" Height="24"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <fa:IconImage Icon="Times" Width="14" Height="14" Foreground="#A0AEC0"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Panel Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            
                            <!-- Category Form Fields -->
                            <StackPanel Visibility="{Binding IsEditingCategoryMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Tên nhóm hàng" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableCategory.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Mô tả" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableCategory.Description, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource FormTextBox}" 
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                         Margin="0,0,0,15"/>

                                <TextBlock Text="Thứ tự hiển thị" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableCategory.DisplayOrder, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>
                            </StackPanel>

                            <!-- Product Form Fields -->
                            <StackPanel Visibility="{Binding IsEditingCategoryMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBlock Text="Nhóm hàng" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Categories}"
                                          SelectedValue="{Binding EditableProduct.CategoryId, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          Margin="0,0,0,15"
                                          Style="{StaticResource ModernComboBoxStyle}"/>

                                <TextBlock Text="Tên hàng hóa" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableProduct.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Giá bán" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableProduct.Price, StringFormat=N0, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="Mô tả" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableProduct.Description, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource FormTextBox}" 
                                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                         Margin="0,0,0,15"/>

                                <TextBlock Text="Link hình ảnh" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditableProduct.ImageUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBox}" Margin="0,0,0,15"/>

                                <CheckBox IsChecked="{Binding EditableProduct.IsAvailable}" 
                                          Content="Đang kinh doanh"
                                          Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Panel Footer -->
                    <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20" Background="#F8FAFC">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Bỏ qua" 
                                    Command="{Binding CloseRightPanelCommand}"
                                    Width="100" Height="36"
                                    Background="White" Foreground="#4A5568" BorderBrush="#CBD5E0" BorderThickness="1"
                                    Margin="0,0,10,0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="Lưu" 
                                    Command="{Binding SavePanelCommand}"
                                    Width="100" Height="36"
                                    Background="#0090DA" Foreground="White" BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay with Spinner -->
        <Grid Grid.RowSpan="2" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <fa:IconImage Icon="Spinner" Width="48" Height="48" Foreground="#0090DA">
                <fa:IconImage.RenderTransform>
                    <RotateTransform Angle="0" CenterX="24" CenterY="24"/>
                </fa:IconImage.RenderTransform>
                <fa:IconImage.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </fa:IconImage.Triggers>
            </fa:IconImage>
        </Grid>
    </Grid>
</UserControl>
