<UserControl x:Class="RestaurantPOS.Desktop.Views.OrderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.Desktop.Views"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="20,20,20,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding NavigateBackCommand}" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="0,0,15,0"
                            ToolTip="Quay lại"
                            Cursor="Hand">
                        <fa:IconImage Icon="ArrowLeft" Width="20" Height="20" Foreground="#64748B"/>
                    </Button>

                    <fa:IconImage Icon="Utensils" Width="24" Height="24" Foreground="#673AB7" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Chi Tiết Bàn" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2D3748"/>
                    <TextBlock Text="{Binding CurrentTable.Name}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#673AB7" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Order Items List -->
        <Grid Grid.Row="1" Margin="20,0,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/> <!-- Orders List -->
                <ColumnDefinition Width="1*"/> <!-- Summary & Actions -->
            </Grid.ColumnDefinitions>

            <!-- Left: Orders List -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0" Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding TableOrders.Count, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <fa:IconImage Icon="ClipboardList" Width="64" Height="64" Foreground="#CBD5E1" Margin="0,0,0,16"/>
                        <TextBlock Text="Chưa có đơn hàng nào" FontSize="16" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Orders List -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TableOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="12" Margin="0,0,10,20" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#64748B" Opacity="0.08" BlurRadius="12" ShadowDepth="4"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Card Header -->
                                            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <fa:IconImage Icon="Receipt" Width="14" Height="14" Foreground="#64748B" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#334155"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Status Badge -->
                                                    <Border HorizontalAlignment="Right" CornerRadius="6" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FEF3C7"/> <!-- Default Pending -->
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#D97706"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                            <Setter Property="Foreground" Value="#059669"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- Items -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,8">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="16,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ProductName}" FontSize="15" Foreground="#334155"/>
                                                                <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="#94A3B8" FontStyle="Italic" Margin="0,2,0,0"
                                                                         Visibility="{Binding Notes, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                            </StackPanel>
                                                            
                                                            <!-- Quantity Controls -->
                                                            <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Margin="16,0" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Width="24" Height="24" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                                        <fa:IconImage Icon="Minus" Width="10" Height="10" Foreground="#64748B"/>
                                                                    </Button>
                                                                    <TextBlock Text="{Binding Quantity}" Margin="8,0" VerticalAlignment="Center" FontWeight="SemiBold" MinWidth="16" TextAlignment="Center"/>
                                                                    <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                            CommandParameter="{Binding}"
                                                                            Width="24" Height="24" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                                        <fa:IconImage Icon="Plus" Width="10" Height="10" Foreground="#64748B"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Border>

                                                            <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                            
                                                            <!-- Remove Button -->
                                                            <Button Grid.Column="3" 
                                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                    CommandParameter="{Binding}"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Hủy món">
                                                                <fa:IconImage Icon="TrashAlt" Width="14" Height="14" Foreground="#EF4444"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Card Footer -->
                                            <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,12" Background="#FAFAFA" CornerRadius="0,0,12,12">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <fa:IconImage Icon="Clock" Width="12" Height="12" Foreground="#94A3B8" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat='HH:mm'}" Foreground="#94A3B8" FontSize="13"/>
                                                    </StackPanel>
                                                    
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <TextBlock Text="Tổng đơn:" Foreground="#64748B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" FontWeight="Bold" Foreground="#334155" FontSize="16"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Summary & Actions -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="10,0,0,0" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Thanh Toán" FontSize="20" FontWeight="Bold" Margin="0,0,0,24" Foreground="#1E293B"/>
                    
                    <!-- Bill Details -->
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Tạm tính" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#334155"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Thuế (0%)" Foreground="#64748B"/>
                        <TextBlock Text="0 đ" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#334155"/>
                    </Grid>
                    
                    <Separator Background="#E2E8F0" Margin="0,8,0,16"/>
                    
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="Tổng cộng" FontSize="16" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" 
                                 FontSize="24" FontWeight="Bold" Foreground="#EF4444" 
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Actions -->
                    <Button Command="{Binding AddMoreItemsCommand}" 
                            Height="48"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Background="#3B82F6"
                            Foreground="White"
                            Margin="0,0,0,12"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Plus" Width="14" Height="14" Foreground="White" Margin="0,0,8,0"/>
                            <TextBlock Text="Thêm Món"/>
                        </StackPanel>
                    </Button>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0"
                                Height="48"
                                Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Foreground="#64748B"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Print" Width="14" Height="14" Foreground="#64748B" Margin="0,0,8,0"/>
                                <TextBlock Text="In Bill"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding PayOrderCommand}" 
                                Height="48"
                                Background="#10B981"
                                Foreground="White"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="CreditCard" Width="14" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Thanh Toán"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Đang tải..." Foreground="#673AB7" Margin="0,10,0,0" FontSize="16"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
