<UserControl x:Class="RestaurantPOS.Desktop.Views.OrderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.Desktop.Views"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20" Margin="20,20,20,10" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding NavigateBackCommand}" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="0,0,15,0"
                            ToolTip="Quay lại"
                            Cursor="Hand">
                        <TextBlock Text="⬅️" FontSize="24"/>
                    </Button>

                    <TextBlock Text="🍽️" FontSize="32" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Chi Tiết Bàn" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#673AB7"/>
                    <TextBlock Text="{Binding CurrentTable.Name}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#673AB7" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Order Items List -->
        <Grid Grid.Row="1" Margin="20,0,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/> <!-- Orders List -->
                <ColumnDefinition Width="1*"/> <!-- Summary & Actions -->
            </Grid.ColumnDefinitions>

            <!-- Left: Orders List -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,10,0" Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                               Visibility="{Binding TableOrders.Count, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Chưa có đơn hàng nào" FontSize="16" Foreground="Gray" Margin="0,10,0,0"/>
                    </StackPanel>
                    
                    <!-- Orders List -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TableOrders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="10">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,5">
                                                <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="#673AB7"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='HH:mm'}" HorizontalAlignment="Right" Foreground="Gray"/>
                                            </Grid>
                                            
                                            <!-- Items in this order -->
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="10,5,0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding ProductName}" FontSize="16"/>
                                                                <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="Gray" FontStyle="Italic" 
                                                                         Visibility="{Binding Notes, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='x{0}'}" Margin="10,0" FontWeight="Bold"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Subtotal, StringFormat='{}{0:N0} đ'}" FontWeight="SemiBold"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Summary & Actions -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="10,0,0,0" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="5" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Tổng Cộng" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="Thành tiền:" FontSize="16"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" 
                                 FontSize="24" FontWeight="Bold" Foreground="#F44336" 
                                 HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator Margin="0,20"/>

                    <Button Command="{Binding AddMoreItemsCommand}" 
                            Content="➕ Thêm Món"
                            Height="50"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="#2196F3"
                            Foreground="White"
                            Margin="0,0,0,10">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Command="{Binding PayOrderCommand}" 
                            Content="💳 Thanh Toán"
                            Height="50"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="#4CAF50"
                            Foreground="White">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Đang tải..." Foreground="#673AB7" Margin="0,10,0,0" FontSize="16"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
