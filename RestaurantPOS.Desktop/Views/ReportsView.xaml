<UserControl x:Class="RestaurantPOS.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RestaurantPOS.Desktop.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:utils="clr-namespace:RestaurantPOS.Desktop.Utilities"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <utils:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / Filter Bar -->
        <materialDesign:Card Grid.Row="0" Margin="20" Padding="20" UniformCornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Báo cáo thống kê" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>
                    
                    <DatePicker SelectedDate="{Binding StartDate}" Width="120" materialDesign:HintAssist.Hint="Từ ngày" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="120" materialDesign:HintAssist.Hint="Đến ngày" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    
                    <Button Command="{Binding LoadReportCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="Sync" Foreground="White" Height="16" Width="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Xem báo cáo"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExportCommand}" CommandParameter="PDF" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0" ToolTip="Xuất PDF">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="FilePdf" Foreground="#D32F2F" Height="16" Width="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Xuất PDF"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExportCommand}" CommandParameter="Excel" Style="{StaticResource MaterialDesignOutlinedButton}" ToolTip="Xuất Excel">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="FileExcel" Foreground="#388E3C" Height="16" Width="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Xuất Excel"/>
                        </StackPanel>
                    </Button>

                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0" IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Margin="20,0,0,0"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Dashboard Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,0,20,20">
                <!-- Summary Cards -->
                <!-- Summary Cards -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Revenue Card -->
                    <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" Padding="20" UniformCornerRadius="10">
                        <materialDesign:Card.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4CAF50" Offset="0"/>
                                <GradientStop Color="#2E7D32" Offset="1"/>
                            </LinearGradientBrush>
                        </materialDesign:Card.Background>
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="DOANH THU HÔM NAY" Foreground="White" Opacity="0.8" FontSize="12" FontWeight="SemiBold"/>
                                <fa:IconImage Icon="DollarSign" Foreground="White" Height="20" Width="20" Opacity="0.5" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="{Binding SalesSummary.TodayRevenue, StringFormat={}{0:N0} đ, FallbackValue=0 đ}" 
                                       Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,10,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                <TextBlock Text="Hôm qua: " Foreground="White" Opacity="0.7" FontSize="12"/>
                                <TextBlock Text="{Binding SalesSummary.YesterdayRevenue, StringFormat={}{0:N0} đ}" Foreground="White" Opacity="1" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Orders Card -->
                    <materialDesign:Card Grid.Column="1" Margin="10,0,10,0" Padding="20" UniformCornerRadius="10">
                        <materialDesign:Card.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2196F3" Offset="0"/>
                                <GradientStop Color="#1565C0" Offset="1"/>
                            </LinearGradientBrush>
                        </materialDesign:Card.Background>
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="ĐƠN HÀNG HÔM NAY" Foreground="White" Opacity="0.8" FontSize="12" FontWeight="SemiBold"/>
                                <fa:IconImage Icon="ShoppingCart" Foreground="White" Height="20" Width="20" Opacity="0.5" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="{Binding SalesSummary.TodayOrders, FallbackValue=0}" 
                                       Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,10,0,0"/>
                            <TextBlock Text="đơn hàng" Foreground="White" Opacity="0.7" FontSize="12" Margin="0,15,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Month Revenue Card -->
                    <materialDesign:Card Grid.Column="2" Margin="10,0,10,0" Padding="20" UniformCornerRadius="10">
                        <materialDesign:Card.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF9800" Offset="0"/>
                                <GradientStop Color="#EF6C00" Offset="1"/>
                            </LinearGradientBrush>
                        </materialDesign:Card.Background>
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="DOANH THU THÁNG" Foreground="White" Opacity="0.8" FontSize="12" FontWeight="SemiBold"/>
                                <fa:IconImage Icon="CalendarAlt" Foreground="White" Height="20" Width="20" Opacity="0.5" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="{Binding SalesSummary.MonthRevenue, StringFormat={}{0:N0} đ, FallbackValue=0 đ}" 
                                       Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,10,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                <TextBlock Text="Tổng đơn: " Foreground="White" Opacity="0.7" FontSize="12"/>
                                <TextBlock Text="{Binding SalesSummary.MonthOrders}" Foreground="White" Opacity="1" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Year Revenue Card -->
                    <materialDesign:Card Grid.Column="3" Margin="10,0,0,0" Padding="20" UniformCornerRadius="10">
                        <materialDesign:Card.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#9C27B0" Offset="0"/>
                                <GradientStop Color="#7B1FA2" Offset="1"/>
                            </LinearGradientBrush>
                        </materialDesign:Card.Background>
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="DOANH THU NĂM" Foreground="White" Opacity="0.8" FontSize="12" FontWeight="SemiBold"/>
                                <fa:IconImage Icon="ChartLine" Foreground="White" Height="20" Width="20" Opacity="0.5" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock Text="{Binding SalesSummary.YearRevenue, StringFormat={}{0:N0} đ, FallbackValue=0 đ}" 
                                       Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,10,0,0"/>
                            <TextBlock Text="Doanh thu lũy kế" Foreground="White" Opacity="0.7" FontSize="12" Margin="0,15,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>



                <!-- Revenue Chart -->
                <materialDesign:Card Margin="0,0,0,20" Padding="0" UniformCornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="20,15">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ChartBar" Foreground="#2196F3" Height="16" Width="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Biểu đồ doanh thu theo thời gian" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </Border>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding RevenueSeries}" LegendLocation="None" Height="250" Margin="20">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Thời gian" Labels="{Binding RevenueLabels}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Doanh thu" LabelFormatter="{Binding RevenueFormatter}" MinValue="0"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </materialDesign:Card>

                <!-- Detailed Reports -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top Products -->
                    <materialDesign:Card Grid.Column="0" Margin="0,0,10,0" Padding="0" UniformCornerRadius="8" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="20,15">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="Trophy" Foreground="#FFD700" Height="16" Width="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="Top sản phẩm bán chạy" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Content -->
                            <Grid Grid.Row="1" MinHeight="300">
                                <!-- List -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                                    <ItemsControl ItemsSource="{Binding TopProducts}" Margin="0,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="20,10" BorderBrush="#FAFAFA" BorderThickness="0,0,0,1" Background="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Icon/Rank -->
                                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#E3F2FD" Margin="0,0,15,0">
                                                            <fa:IconImage Icon="BoxOpen" Foreground="#1565C0" Height="16" Width="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        
                                                        <!-- Info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <TextBlock Text="{Binding QuantitySold}" FontWeight="Bold" Foreground="#4CAF50"/>
                                                                <TextBlock Text=" đã bán" Foreground="Gray" FontSize="12"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        
                                                        <!-- Revenue -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:N0} đ}" FontWeight="Bold" FontSize="14" Foreground="#333"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Empty State -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                            Visibility="{Binding TopProducts.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                                    <fa:IconImage Icon="Inbox" Foreground="#DDD" Height="40" Width="40" Margin="0,0,0,10"/>
                                    <TextBlock Text="Chưa có dữ liệu" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Category Breakdown -->
                    <materialDesign:Card Grid.Column="1" Margin="10,0,0,0" Padding="0" UniformCornerRadius="8" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="20,15">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="ChartPie" Foreground="#FF9800" Height="16" Width="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="Doanh thu theo nhóm" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                            </Border>
                            
                            <Grid Grid.Row="1" MinHeight="300">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Pie Chart -->
                                <lvc:PieChart Grid.Row="0" Series="{Binding CategorySeries}" LegendLocation="Right" Height="200" Margin="0,10,0,0">
                                    <lvc:PieChart.ChartLegend>
                                        <lvc:DefaultLegend BulletSize="10"/>
                                    </lvc:PieChart.ChartLegend>
                                </lvc:PieChart>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                    <ItemsControl ItemsSource="{Binding CategoryRevenue}" Margin="20">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,20">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" Foreground="#333"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:N0} đ}" FontWeight="Bold" Foreground="#333"/>
                                                            <TextBlock Text="{Binding Percentage, StringFormat=' ({0:N1}%)'}" Foreground="Gray" Margin="5,0,0,0" FontSize="12" VerticalAlignment="Bottom"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <ProgressBar Grid.Row="1" Value="{Binding Percentage}" Maximum="100" Height="6" 
                                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                                                 Background="#F5F5F5" BorderThickness="0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Empty State -->
                                <StackPanel Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                            Visibility="{Binding CategoryRevenue.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                                    <fa:IconImage Icon="ChartPie" Foreground="#DDD" Height="40" Width="40" Margin="0,0,0,10"/>
                                    <TextBlock Text="Chưa có dữ liệu" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
