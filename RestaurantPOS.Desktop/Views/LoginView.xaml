<UserControl x:Class="RestaurantPOS.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <Grid>
        <!-- Background with Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1E293B" Offset="1"/>
                <GradientStop Color="#334155" Offset="0.5"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- Fallback Gradient / Overlay -->
        <Border Background="#0F172A" Opacity="0.85"/>
        
        <!-- Decorative Elements -->
        <Canvas>
            <Ellipse Width="600" Height="600" Fill="#7C3AED" Opacity="0.2" Canvas.Left="-200" Canvas.Top="-200">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="400" Height="400" Fill="#2563EB" Opacity="0.2" Canvas.Right="-100" Canvas.Bottom="-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- Login Card -->
        <Border Width="420" 
                Background="#CCFFFFFF" 
                CornerRadius="24"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="40">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="40" ShadowDepth="10"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Border Width="70" Height="70" CornerRadius="20" Background="#2563EB" Margin="0,0,0,15">
                        <Border.Effect>
                            <DropShadowEffect Color="#2563EB" BlurRadius="20" Opacity="0.4"/>
                        </Border.Effect>
                        <fa:IconImage Icon="Utensils" Foreground="White" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SMART ORDER" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               Foreground="#1E293B"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Đăng nhập để tiếp tục" 
                               FontSize="14" 
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Username -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <TextBlock Text="Tên đăng nhập" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="User" Foreground="#94A3B8" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0,0,15,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Password -->
                <StackPanel Grid.Row="2" Margin="0,0,0,30">
                    <TextBlock Text="Mật khẩu" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <fa:IconImage Icon="Lock" Foreground="#94A3B8" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <PasswordBox Grid.Column="1"
                                         x:Name="PasswordBox"
                                         FontSize="15"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0,0,15,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Error Message -->
                <Border Grid.Row="3" 
                        Background="#FEF2F2" 
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,20"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <fa:IconImage Icon="CircleExclamation" Foreground="#DC2626" Width="14" Height="14" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="#DC2626"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Login Button -->
                <Button Grid.Row="4"
                        Command="{Binding LoginCommand}"
                        Height="54"
                        Cursor="Hand"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2563EB" Offset="0"/>
                                        <GradientStop Color="#4F46E5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <TextBlock Text="Đăng nhập" 
                                       Foreground="White" 
                                       FontSize="16" 
                                       FontWeight="Bold"/>
                            <fa:IconImage Icon="ArrowRight" Foreground="White" Width="14" Height="14" Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <fa:IconImage Icon="Spinner" Foreground="White" Width="16" Height="16" Margin="0,0,10,0" RenderTransformOrigin="0.5, 0.5">
                                <fa:IconImage.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </fa:IconImage.RenderTransform>
                                <fa:IconImage.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </fa:IconImage.Triggers>
                            </fa:IconImage>
                            <TextBlock Text="Đang xử lý..." 
                                       Foreground="White" 
                                       FontSize="16" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Button>

                <!-- Footer -->
                <TextBlock Grid.Row="5"
                           Text="© 2025 Smart Order System"
                           FontSize="12"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           Margin="0,30,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
