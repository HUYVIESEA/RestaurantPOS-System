<UserControl x:Class="RestaurantPOS.Desktop.Views.PaymentSettingsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Width="500">
    
    <materialDesign:Card UniformCornerRadius="12" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" 
                    CornerRadius="12,12,0,0" Padding="20">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <fa:IconImage Icon="CreditCard" Foreground="White" Height="24" Width="24" Margin="0,0,10,0"/>
                        <TextBlock Text="Cài đặt thanh toán VietQR" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <!-- Security Badge -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <fa:IconImage Icon="Lock" Foreground="#4CAF50" Height="16" Width="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Bảo mật cao" Foreground="#A5D6A7" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25">
                    
                    <!-- Status Message -->
                    <Border Background="#FFF3E0" CornerRadius="6" Padding="12" Margin="0,0,0,20"
                            Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="CheckCircle" Foreground="#FF9800" Height="16" Width="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Đã có cấu hình. Nhập mật khẩu để cập nhật." 
                                       Foreground="#E65100" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFEBEE" CornerRadius="6" Padding="12" Margin="0,0,0,20"
                            Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage Icon="ExclamationTriangle" Foreground="#F44336" Height="16" Width="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Chưa có cấu hình thanh toán. Vui lòng thiết lập." 
                                       Foreground="#C62828" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Bank Selection -->
                    <TextBlock Text="Thông tin tài khoản nhận tiền" FontWeight="Bold" FontSize="14" 
                               Margin="0,0,0,15" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    
                    <ComboBox ItemsSource="{Binding Banks}" 
                              SelectedItem="{Binding SelectedBank}"
                              DisplayMemberPath="DisplayName"
                              materialDesign:HintAssist.Hint="Chọn ngân hàng *"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,15"
                              IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                    
                    <TextBox Text="{Binding AccountNumber, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Số tài khoản *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,15"
                             IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                    
                    <TextBox Text="{Binding AccountName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Tên chủ tài khoản (KHÔNG DẤU) *"
                             CharacterCasing="Upper"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,25"
                             IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>

                    <!-- Security Section -->
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <fa:IconImage Icon="ShieldAlt" Foreground="#1976D2" Height="18" Width="18" Margin="0,0,8,0"/>
                                <TextBlock Text="Xác nhận bảo mật" FontWeight="Bold" Foreground="#1565C0"/>
                            </StackPanel>
                            
                            <TextBlock Text="Nhập mật khẩu tài khoản của bạn để xác nhận thay đổi:" 
                                       Foreground="#1976D2" Margin="0,0,0,10" TextWrapping="Wrap" FontSize="12"/>
                            
                            <PasswordBox x:Name="PasswordBox"
                                         materialDesign:HintAssist.Hint="Mật khẩu *"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Note -->
                    <TextBlock Text="* Thông tin bắt buộc. Mật khẩu dùng để xác thực quyền thay đổi cài đặt." 
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EEE" 
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Loading indicator -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Width="100" Height="4" 
                                     Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                        <TextBlock Text="Đang xử lý..." Margin="10,0,0,0" Foreground="Gray"/>
                    </StackPanel>
                    
                    <!-- Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Content="Hủy" Margin="0,0,10,0"
                                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                            <Button.CommandParameter>
                                <sys:Boolean>False</sys:Boolean>
                            </Button.CommandParameter>
                        </Button>
                        
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                                Content="Lưu cài đặt"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding CanSave}">
                            <Button.CommandParameter>
                                <sys:Boolean>True</sys:Boolean>
                            </Button.CommandParameter>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </materialDesign:Card>
</UserControl>
