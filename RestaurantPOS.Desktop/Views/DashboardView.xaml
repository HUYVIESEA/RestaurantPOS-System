<UserControl x:Class="RestaurantPOS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
        <StackPanel Margin="30,20">
            
            <!-- Page Title -->
            <TextBlock Text="Tổng quan" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2D3748"
                       Margin="0,0,0,20"/>

            <!-- Statistics Cards Row 1 -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Revenue Card -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Doanh thu hôm nay" FontSize="13" Foreground="#718096" Margin="0,0,0,8"/>
                        <TextBlock Text="0 đ" FontSize="26" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↗" FontSize="14" Foreground="#10B981" Margin="0,0,3,0"/>
                            <TextBlock Text="+0% so với hôm qua" FontSize="11" Foreground="#10B981"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Orders Card -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="5,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Đơn hàng" FontSize="13" Foreground="#718096" Margin="0,0,0,8"/>
                        <TextBlock Text="0" FontSize="26" FontWeight="Bold" Foreground="#3B82F6" Margin="0,0,0,5"/>
                        <TextBlock Text="Đơn hàng hôm nay" FontSize="11" Foreground="#A0AEC0"/>
                    </StackPanel>
                </Border>

                <!-- Tables Card -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" Margin="5,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Bàn đang phục vụ" FontSize="13" Foreground="#718096" Margin="0,0,0,8"/>
                        <TextBlock Text="0/0" FontSize="26" FontWeight="Bold" Foreground="#F59E0B" Margin="0,0,0,5"/>
                        <TextBlock Text="Tổng số bàn" FontSize="11" Foreground="#A0AEC0"/>
                    </StackPanel>
                </Border>

                <!-- Staff Card -->
                <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Nhân viên" FontSize="13" Foreground="#718096" Margin="0,0,0,8"/>
                        <TextBlock Text="0" FontSize="26" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,0,0,5"/>
                        <TextBlock Text="Đang hoạt động" FontSize="11" Foreground="#A0AEC0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions Section -->
            <TextBlock Text="Thao tác nhanh" 
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       Foreground="#2D3748"
                       Margin="0,10,0,15"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tables Button -->
                <Button Grid.Column="0" 
                        Command="{Binding NavigateToTablesCommand}"
                        Cursor="Hand"
                        Margin="0,0,10,0"
                        Height="140">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Width="60" Height="60" CornerRadius="30" Background="#EBF5FF" Margin="0,0,0,12">
                                            <TextBlock Text="🪑" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Quản lý Bàn" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#F7FAFC" CornerRadius="0,0,8,8" Padding="12,8">
                                        <TextBlock Text="Xem và quản lý bàn ăn" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="3"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Orders Button -->
                <Button Grid.Column="1" 
                        Command="{Binding NavigateToOrdersCommand}"
                        Cursor="Hand"
                        Margin="5,0"
                        Height="140">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Width="60" Height="60" CornerRadius="30" Background="#F0FDF4" Margin="0,0,0,12">
                                            <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Danh sách Đơn" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#F7FAFC" CornerRadius="0,0,8,8" Padding="12,8">
                                        <TextBlock Text="Xem tất cả đơn hàng" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="3"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Users Button -->
                <Button Grid.Column="2" 
                        Command="{Binding NavigateToUsersCommand}"
                        Cursor="Hand"
                        Margin="10,0,0,0"
                        Height="140">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Width="60" Height="60" CornerRadius="30" Background="#FEF3C7" Margin="0,0,0,12">
                                            <TextBlock Text="👥" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Quản lý Người dùng" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="#F7FAFC" CornerRadius="0,0,8,8" Padding="12,8">
                                        <TextBlock Text="Quản lý tài khoản nhân viên" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="3"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Revenue Chart Section -->
            <TextBlock Text="Doanh thu 7 ngày qua" 
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       Foreground="#2D3748"
                       Margin="0,30,0,15"/>

            <Border Background="White" CornerRadius="8" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid Height="200">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Chart Bars -->
                    <Grid Grid.Row="0" VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mon -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="100" Background="#E2E8F0" CornerRadius="4,4,0,0" ToolTip="1,200,000 đ">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>
                        
                        <!-- Tue -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="140" Background="#E2E8F0" CornerRadius="4,4,0,0" ToolTip="2,500,000 đ">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>

                        <!-- Wed -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="80" Background="#E2E8F0" CornerRadius="4,4,0,0" ToolTip="800,000 đ">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>

                        <!-- Thu -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="160" Background="#E2E8F0" CornerRadius="4,4,0,0" ToolTip="3,100,000 đ">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>

                        <!-- Fri -->
                        <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="120" Background="#E2E8F0" CornerRadius="4,4,0,0" ToolTip="1,800,000 đ">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>

                        <!-- Sat -->
                        <StackPanel Grid.Column="5" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="180" Background="#3B82F6" CornerRadius="4,4,0,0" ToolTip="4,500,000 đ">
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" Opacity="0.4" BlurRadius="10" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                        </StackPanel>

                        <!-- Sun -->
                        <StackPanel Grid.Column="6" VerticalAlignment="Bottom" Margin="10,0">
                            <Border Height="150" Background="#E2E8F0" CornerRadius="4,4,0,0" ToolTip="2,900,000 đ">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- X Axis Labels -->
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="T2" HorizontalAlignment="Center" Foreground="#718096"/>
                        <TextBlock Grid.Column="1" Text="T3" HorizontalAlignment="Center" Foreground="#718096"/>
                        <TextBlock Grid.Column="2" Text="T4" HorizontalAlignment="Center" Foreground="#718096"/>
                        <TextBlock Grid.Column="3" Text="T5" HorizontalAlignment="Center" Foreground="#718096"/>
                        <TextBlock Grid.Column="4" Text="T6" HorizontalAlignment="Center" Foreground="#718096"/>
                        <TextBlock Grid.Column="5" Text="T7" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#3B82F6"/>
                        <TextBlock Grid.Column="6" Text="CN" HorizontalAlignment="Center" Foreground="#718096"/>
                    </Grid>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
