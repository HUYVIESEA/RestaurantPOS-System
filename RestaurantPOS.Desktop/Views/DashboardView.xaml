<UserControl x:Class="RestaurantPOS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:converters="clr-namespace:RestaurantPOS.Desktop.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <UserControl.Resources>
        <converters:BarHeightConverter x:Key="BarHeightConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F8FAFC">
        <StackPanel Margin="30,20">
            
            <!-- Page Title -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="{Binding WelcomeMessage}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#1E293B"/>
                <TextBlock Text="Đây là tổng quan tình hình kinh doanh hôm nay." 
                           FontSize="14" 
                           Foreground="#64748B"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Statistics Cards Row -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Revenue Card -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                    </Border.Effect>
                    <Grid>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Border Width="40" Height="40" CornerRadius="10" Background="#DCFCE7">
                                    <fa:IconImage Icon="DollarSign" Width="20" Height="20" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Doanh thu" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding RevenueToday, StringFormat={}{0:N0} đ}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="ArrowUp" Width="12" Height="12" Foreground="#16A34A" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding RevenueGrowth, StringFormat={}{0}% so với hôm qua}" FontSize="12" Foreground="#16A34A" FontWeight="Medium"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Orders Card -->
                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" Margin="10,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#DBEAFE">
                                <fa:IconImage Icon="FileInvoice" Width="20" Height="20" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Đơn hàng" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding OrdersToday}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,5"/>
                        <TextBlock Text="Đơn hàng hôm nay" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </Border>

                <!-- Tables Card -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20" Margin="10,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#FEF3C7">
                                <fa:IconImage Icon="Chair" Width="20" Height="20" Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Bàn phục vụ" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding ActiveTables}" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="/" FontSize="18" Foreground="#94A3B8" Margin="2,0,2,4" VerticalAlignment="Bottom"/>
                            <TextBlock Text="{Binding TotalTables}" FontSize="18" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                        </StackPanel>
                        <TextBlock Text="Bàn đang có khách" FontSize="12" Foreground="#64748B" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Staff Card -->
                <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="40" Height="40" CornerRadius="10" Background="#F3E8FF">
                                <fa:IconImage Icon="Users" Width="20" Height="20" Foreground="#9333EA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Nhân sự" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveStaff}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,5"/>
                        <TextBlock Text="Nhân viên đang làm việc" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions Section -->
            <TextBlock Text="Truy cập nhanh" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#1E293B"
                       Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tables Button -->
                <Button Grid.Column="0" 
                        Command="{Binding NavigateToTablesCommand}"
                        Cursor="Hand"
                        Margin="0,0,10,0"
                        Height="120"
                        BorderThickness="0"
                        Background="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <fa:IconImage Icon="Chair" Width="32" Height="32" Foreground="#3B82F6" Margin="0,0,0,10"/>
                                        <TextBlock Text="Quản lý Bàn" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Create Order Button -->
                <Button Grid.Column="1" 
                        Command="{Binding NavigateToCreateOrderCommand}"
                        Cursor="Hand"
                        Margin="10,0"
                        Height="120"
                        BorderThickness="0"
                        Background="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <fa:IconImage Icon="PlusCircle" Width="32" Height="32" Foreground="#10B981" Margin="0,0,0,10"/>
                                        <TextBlock Text="Tạo Đơn Mới" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Orders Button -->
                <Button Grid.Column="2" 
                        Command="{Binding NavigateToOrdersCommand}"
                        Cursor="Hand"
                        Margin="10,0"
                        Height="120"
                        BorderThickness="0"
                        Background="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <fa:IconImage Icon="ListAlt" Width="32" Height="32" Foreground="#F59E0B" Margin="0,0,0,10"/>
                                        <TextBlock Text="Danh sách Đơn" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Menu Button -->
                <Button Grid.Column="3" 
                        Command="{Binding NavigateToMenuCommand}"
                        Cursor="Hand"
                        Margin="10,0,0,0"
                        Height="120"
                        BorderThickness="0"
                        Background="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <fa:IconImage Icon="BookOpen" Width="32" Height="32" Foreground="#8B5CF6" Margin="0,0,0,10"/>
                                        <TextBlock Text="Thực đơn" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Charts and Lists Section -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Revenue Chart -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Biểu đồ doanh thu tuần" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#1E293B"
                               Margin="0,0,0,15"/>

                    <Border Background="White" CornerRadius="12" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="200"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Chart Bars -->
                            <ItemsControl ItemsSource="{Binding WeeklyRevenue}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Bottom" Margin="10,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Bar -->
                                            <Border Grid.Row="0" 
                                                    Width="40" 
                                                    CornerRadius="6,6,0,0" 
                                                    Background="#3B82F6"
                                                    VerticalAlignment="Bottom"
                                                    ToolTip="{Binding Amount, StringFormat={}{0:N0} đ}">
                                                <Border.Height>
                                                    <MultiBinding Converter="{StaticResource BarHeightConverter}">
                                                        <Binding Path="Amount"/>
                                                        <Binding Path="DataContext.MaxRevenue" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        <Binding Source="200.0"/> <!-- Container Height -->
                                                    </MultiBinding>
                                                </Border.Height>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#2563EB"/>
                                                                <Setter Property="Opacity" Value="0.9"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            
                                            <!-- Label -->
                                            <TextBlock Grid.Row="1" 
                                                       Text="{Binding Day}" 
                                                       HorizontalAlignment="Center" 
                                                       Margin="0,10,0,0"
                                                       Foreground="#64748B"
                                                       FontWeight="Medium"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Top Selling Items -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Món bán chạy" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#1E293B"
                               Margin="0,0,0,15"/>
                    
                    <Border Background="White" CornerRadius="12" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                        </Border.Effect>
                        <ItemsControl ItemsSource="{Binding TopSellingItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#F1F5F9" Margin="0,0,12,0">
                                            <fa:IconImage Icon="Utensils" Width="16" Height="16" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding Quantity, StringFormat={}{0} đã bán}" FontSize="12" Foreground="#64748B"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding TotalRevenue, StringFormat={}{0:N0} đ}" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Recent Orders Section -->
            <TextBlock Text="Đơn hàng gần đây" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#1E293B"
                       Margin="0,0,0,15"/>

            <Border Background="White" CornerRadius="12" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="4"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding RecentOrders}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          BorderThickness="0"
                          Background="Transparent"
                          RowHeight="50"
                          Padding="10">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã đơn" Binding="{Binding OrderNumber}" Width="Auto" FontWeight="Medium" Foreground="#3B82F6"/>
                        <DataGridTextColumn Header="Bàn" Binding="{Binding TableName}" Width="Auto"/>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" Width="*"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat={}{0:N0} đ}" Width="*" FontWeight="Bold"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E2E8F0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Medium">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#475569"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
