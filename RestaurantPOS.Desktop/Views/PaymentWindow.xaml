<Window x:Class="RestaurantPOS.Desktop.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        mc:Ignorable="d"
        Title="Thanh toán" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="20" ShadowDepth="5"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Total Amount -->
                <RowDefinition Height="Auto"/> <!-- Method Selection -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Thanh toán đơn hàng" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#1E293B"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Total Amount -->
            <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Tổng tiền thanh toán" Foreground="#64748B" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="#2563EB"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Payment Method -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cash Button -->
                <Button Command="{Binding SelectCashCommand}" Margin="0,0,5,0" Height="50">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="8" BorderThickness="2" Background="White" BorderBrush="#E2E8F0">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <fa:IconImage Icon="MoneyBillWave" Width="16" Height="16" Margin="0,0,8,0" Foreground="#64748B"/>
                                                <TextBlock Text="Tiền mặt" FontWeight="SemiBold" Foreground="#64748B"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding PaymentMethod}" Value="Cash">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Transfer Button -->
                <Button Grid.Column="1" Command="{Binding SelectTransferCommand}" Margin="5,0,0,0" Height="50">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="8" BorderThickness="2" Background="White" BorderBrush="#E2E8F0">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <fa:IconImage Icon="Qrcode" Width="16" Height="16" Margin="0,0,8,0" Foreground="#64748B"/>
                                                <TextBlock Text="Chuyển khoản" FontWeight="SemiBold" Foreground="#64748B"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding PaymentMethod}" Value="Transfer">
                                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <!-- Cash Content -->
                <StackPanel Visibility="{Binding PaymentMethod, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Cash}">
                    <TextBlock Text="Tiền khách đưa" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="5">
                        <TextBox Text="{Binding ReceivedAmount, StringFormat=N0, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18"
                                 FontWeight="Medium"
                                 Padding="10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                    </Border>
                    
                    <Grid Margin="0,15,0,0">
                        <TextBlock Text="Tiền thừa trả khách" VerticalAlignment="Center" Foreground="#64748B"/>
                        <TextBlock Text="{Binding ChangeAmount, StringFormat={}{0:N0} đ}" 
                                   HorizontalAlignment="Right" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="#10B981"/>
                    </Grid>
                </StackPanel>

                <!-- Transfer Content -->
                <StackPanel Visibility="{Binding PaymentMethod, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Transfer}">
                    <Border Width="200" Height="200" Background="#F8FAFC" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Grid>
                            <!-- Placeholder while loading or if failed -->
                            <fa:IconImage Icon="Qrcode" Width="120" Height="120" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            
                            <!-- Real QR Code -->
                            <Image Source="{Binding QrCodeUrl}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Quét mã QR để thanh toán" HorizontalAlignment="Center" Foreground="#64748B"/>
                    <TextBlock Text="(Mã QR tự động tạo theo số tiền)" FontSize="11" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding CancelCommand}" 
                        Content="Hủy bỏ"
                        Height="45"
                        Margin="0,0,5,0"
                        Background="#F1F5F9"
                        Foreground="#64748B"
                        FontWeight="SemiBold"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="1" 
                        Command="{Binding ConfirmCommand}" 
                        Content="Xác nhận thanh toán"
                        Height="45"
                        Margin="5,0,0,0"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        IsEnabled="{Binding CanConfirm}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="border" Property="Background" Value="#94A3B8"/>
                                                <Setter Property="Foreground" Value="#E2E8F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
