<Window x:Class="RestaurantPOS.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RestaurantPOS.Desktop.ViewModels"
        xmlns:converters="clr-namespace:RestaurantPOS.Desktop.Converters"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        mc:Ignorable="d"
        Title="Smart Order" 
        Icon="pack://application:,,,/Resources/icons/restaurant.ico"
        Height="768" 
        Width="1366"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#F5F5F5">
    
    <Window.Resources>
        <!-- Converter to check if current view is LoginViewModel -->
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/> <!-- Slate 400 -->
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- Window Control Buttons (Always visible) -->
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Panel.ZIndex="999"
                    Margin="0,0,0,0">
            <Button Click="MinimizeWindow_Click"
                    Width="45" 
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#718096"
                    Cursor="Hand"
                    ToolTip="Thu nhỏ">
                <fa:IconImage Icon="WindowMinimize" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Button>
            <Button Click="MaximizeWindow_Click"
                    Width="45" 
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#718096"
                    Cursor="Hand"
                    ToolTip="Phóng to">
                <fa:IconImage Icon="Square" Width="14" Height="14" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Button>
            <Button Click="CloseWindow_Click"
                    Width="45" 
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#718096"
                    Cursor="Hand"
                    ToolTip="Đóng">
                <fa:IconImage Icon="Xmark" Width="16" Height="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F44336"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Full screen for Login -->
        <ContentControl Content="{Binding CurrentViewModel}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
        
        <!-- Main Layout (with Sidebar) for other views -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Navigation -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0.0"/>
                        <GradientStop Color="#1E293B" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo & Brand -->
                    <Border Grid.Row="0" Padding="20,30,20,20">
                        <StackPanel>
                            <Border Width="50" Height="50" CornerRadius="12" Background="#3B82F6" Margin="0,0,0,15" HorizontalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <fa:IconImage Icon="Utensils" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="SMART ORDER" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Menu -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10">
                        <StackPanel>
                            <!-- Dashboard -->
                            <Button Command="{Binding NavigateToDashboardCommand}" Tag="Dashboard">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Dashboard">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3B82F6" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="ChartPie" Width="18" Height="18" Margin="0,0,12,0" 
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Tổng quan" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Tables -->
                            <Button Command="{Binding NavigateToTablesCommand}" Tag="TableManagement">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="TableManagement">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3B82F6" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="Chair" Width="18" Height="18" Margin="0,0,12,0"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Phòng bàn" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Orders -->
                            <Button Command="{Binding NavigateToOrdersCommand}" Tag="OrderList">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="OrderList">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3B82F6" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="FileInvoice" Width="18" Height="18" Margin="0,0,12,0"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Đơn hàng" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Menu -->
                            <Button Command="{Binding NavigateToMenuCommand}" Tag="MenuManagement"
                                    Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="MenuManagement">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3B82F6" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="Utensils" Width="18" Height="18" Margin="0,0,12,0"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Thực đơn" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Users -->
                            <Button Command="{Binding NavigateToUsersCommand}" Tag="UserManagement"
                                    Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="UserManagement">
                                                <Setter Property="Background" Value="#3B82F6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#3B82F6" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="Users" Width="18" Height="18" Margin="0,0,12,0"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Người dùng" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- User Info & Logout -->
                    <Border Grid.Row="2" Padding="20" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#334155" Margin="0,0,12,0">
                                <TextBlock Text="{Binding CurrentUser.Username, Converter={StaticResource FirstLetterConverter}}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.FullName}" 
                                           Foreground="White" 
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CurrentUser.Role}" 
                                           Foreground="#94A3B8" 
                                           FontSize="12"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Command="{Binding LogoutCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8"
                                    Cursor="Hand"
                                    ToolTip="Đăng xuất">
                                <fa:IconImage Icon="RightFromBracket" Foreground="#EF4444" Width="16" Height="16"/>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#334155"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Bar -->
                        <Border Grid.Column="0" 
                                Background="#F5F5F5" 
                                CornerRadius="6" 
                                Padding="12,8"
                                MaxWidth="400"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <fa:IconImage Grid.Column="0" Icon="MagnifyingGlass" Foreground="#718096" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" 
                                         BorderThickness="0" 
                                         Background="Transparent"
                                         VerticalAlignment="Center"
                                         FontSize="13"
                                         Text="Tìm kiếm..."/>
                            </Grid>
                        </Border>

                        <!-- Right Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Background="Transparent" 
                                    BorderThickness="0"
                                    Padding="10"
                                    Cursor="Hand"
                                    ToolTip="Thông báo">
                                <fa:IconImage Icon="Bell" Foreground="#718096" Width="18" Height="18"/>
                            </Button>
                            <Button Background="Transparent" 
                                    BorderThickness="0"
                                    Padding="10"
                                    Margin="5,0,0,0"
                                    Cursor="Hand"
                                    ToolTip="Cài đặt">
                                <fa:IconImage Icon="Gear" Foreground="#718096" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <ContentControl Grid.Row="1" 
                                Content="{Binding CurrentViewModel}"
                                Margin="0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
