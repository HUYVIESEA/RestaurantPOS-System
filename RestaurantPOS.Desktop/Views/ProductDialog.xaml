<UserControl x:Class="RestaurantPOS.Desktop.Views.ProductDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Width="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBox materialDesign:HintAssist.Hint="Tên sản phẩm" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Name}" Margin="0,0,0,10"/>
            
            <TextBox materialDesign:HintAssist.Hint="Giá bán" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Price}" Margin="0,0,0,10"/>

            <TextBox materialDesign:HintAssist.Hint="Đơn vị tính" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Unit}" Margin="0,0,0,10"/>
            
            <ComboBox materialDesign:HintAssist.Hint="Danh mục" Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedValuePath="Id"
                      SelectedValue="{Binding Product.CategoryId}" Margin="0,0,0,10"/>
            
            <TextBox materialDesign:HintAssist.Hint="URL Hình ảnh" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.ImageUrl}" Margin="0,0,0,10"/>
            
            <TextBox materialDesign:HintAssist.Hint="Mô tả" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Description}" Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}" IsCancel="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static sys:Boolean.FalseString}"
                    Content="Hủy" Margin="0,0,10,0"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            
            <Button Style="{StaticResource MaterialDesignRaisedButton}" IsDefault="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static sys:Boolean.TrueString}"
                    Content="Lưu"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
        </StackPanel>
    </Grid>
</UserControl>
