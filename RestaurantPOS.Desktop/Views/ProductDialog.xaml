<UserControl x:Class="RestaurantPOS.Desktop.Views.ProductDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Width="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,10"/>
        
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10">
             <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <StackPanel Grid.Row="1">
            <TextBox materialDesign:HintAssist.Hint="Tên sản phẩm" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Name}" Margin="0,0,0,10"/>
            
            <TextBox materialDesign:HintAssist.Hint="Giá bán" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Price}" Margin="0,0,0,10"/>

            <TextBox materialDesign:HintAssist.Hint="Đơn vị tính" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Unit}" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">
                <TextBox materialDesign:HintAssist.Hint="Tồn kho" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Text="{Binding Product.StockQuantity}" Width="150" Margin="0,0,20,10"/>
                         
                <CheckBox Content="Đang kinh doanh" IsChecked="{Binding Product.IsAvailable}" VerticalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
            
            <ComboBox materialDesign:HintAssist.Hint="Danh mục" Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                      ItemsSource="{Binding Categories}" DisplayMemberPath="Name" SelectedValuePath="Id"
                      SelectedValue="{Binding Product.CategoryId}" Margin="0,0,0,10"/>
            
            <!-- Image Upload Section -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Width="80" Height="80" CornerRadius="5" Background="#F0F0F0" ClipToBounds="True" Margin="0,0,10,0">
                    <Grid>
                        <materialDesign:PackIcon Kind="Image" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Product.ImageUrl}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Product.ImageUrl}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>

                        <Image Source="{Binding Product.ImageUrl}" Stretch="UniformToFill">
                             <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Product.ImageUrl}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Product.ImageUrl}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                             </Image.Style>
                        </Image>
                    </Grid>
                </Border>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Hình ảnh sản phẩm" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="Chọn ảnh..." 
                            Command="{Binding SelectImageCommand}" HorizontalAlignment="Left" Height="30" Padding="10,0"/>
                    <ProgressBar IsIndeterminate="True" Value="0" Height="2" Margin="0,5,0,0"
                                 Visibility="{Binding IsUploading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>

            <TextBox materialDesign:HintAssist.Hint="Mô tả" Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Text="{Binding Product.Description}" Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}" IsCancel="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static sys:Boolean.FalseString}"
                    Content="Hủy" Margin="0,0,10,0"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            
            <Button Style="{StaticResource MaterialDesignRaisedButton}" IsDefault="True"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Static sys:Boolean.TrueString}"
                    Content="Lưu"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
        </StackPanel>
    </Grid>
</UserControl>
