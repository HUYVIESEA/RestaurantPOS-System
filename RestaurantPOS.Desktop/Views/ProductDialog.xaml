<Window x:Class="RestaurantPOS.Desktop.Views.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="thực đơn"
        Height="550"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="DialogTitle"
                      Text="Thêm thực đơn mới" 
                      FontSize="24" 
                      FontWeight="Bold"
                      Foreground="{StaticResource BunBrownBrush}"/>
            <TextBlock Text="Nhập thông tin thực đơn" 
                      FontSize="14"
                      Opacity="0.7"
                      Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Product Name -->
                <TextBox x:Name="NameTextBox"
                        materialDesign:HintAssist.Hint="Tên thực đơn *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,16"
                        FontSize="14"/>

                <!-- Description -->
                <TextBox x:Name="DescriptionTextBox"
                        materialDesign:HintAssist.Hint="Mô tả"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        MinLines="3"
                        MaxLines="5"
                        Margin="0,0,0,16"
                        FontSize="14"/>

                <!-- Price -->
                <TextBox x:Name="PriceTextBox"
                        materialDesign:HintAssist.Hint="Giá (VNĐ) *"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,16"
                        FontSize="14"
                        PreviewTextInput="NumberValidationTextBox"/>

                <!-- Category -->
                <ComboBox x:Name="CategoryComboBox"
                         materialDesign:HintAssist.Hint="Danh mục *"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         DisplayMemberPath="Name"
                         SelectedValuePath="Id"
                         Margin="0,0,0,16"
                         FontSize="14"/>

                <!-- Image URL -->
                <TextBox x:Name="ImageUrlTextBox"
                        materialDesign:HintAssist.Hint="URL hình ảnh (hoặc emoji)"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,16"
                        FontSize="14"/>

                <!-- Is Available -->
                <CheckBox x:Name="IsAvailableCheckBox"
                         Content="Còn hàng"
                         IsChecked="True"
                         Margin="0,0,0,16"
                         FontSize="14"/>

                <!-- Validation Message -->
                <TextBlock x:Name="ValidationMessage"
                          Foreground="#e74c3c"
                          FontSize="12"
                          TextWrapping="Wrap"
                          Visibility="Collapsed"
                          Margin="0,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                   Content="Hủy"
                   Style="{StaticResource SecondaryButton}"
                   Click="CancelButton_Click"
                   Margin="0,0,8,0"
                   Width="100"/>

            <Button Grid.Column="2"
                   x:Name="SaveButton"
                   Content="Lưu"
                   Style="{StaticResource PrimaryButton}"
                   Click="SaveButton_Click"
                   Width="100"/>
        </Grid>
    </Grid>
</Window>
