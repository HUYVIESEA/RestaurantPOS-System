<UserControl x:Class="RestaurantPOS.Desktop.Views.OrderListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border Grid.Row="0" Background="White" Padding="30,20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Danh sách Đơn hàng" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#2D3748"
                               VerticalAlignment="Center"/>
                    <Border Background="#EBF5FF" 
                            CornerRadius="4" 
                            Padding="8,4" 
                            Margin="15,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Orders.Count, StringFormat='{}Tổng: {0} đơn'}" 
                                   FontSize="12" 
                                   Foreground="#3B82F6"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding RefreshCommand}" 
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Padding="12,8"
                            Cursor="Hand"
                            Style="{StaticResource ModernButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔄" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Làm mới" FontSize="13" Foreground="#4A5568"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="30,15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Lọc theo trạng thái:" 
                           FontSize="13" 
                           Foreground="#718096"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                
                <ComboBox SelectedValue="{Binding FilterStatus}"
                          SelectedValuePath="Tag"
                          MinWidth="180"
                          Padding="12,8"
                          BorderBrush="#E0E0E0"
                          FontSize="13">
                    <ComboBoxItem Content="Tất cả trạng thái" Tag="All" IsSelected="True"/>
                    <ComboBoxItem Content="Chờ xử lý" Tag="Pending"/>
                    <ComboBoxItem Content="Đang chuẩn bị" Tag="Preparing"/>
                    <ComboBoxItem Content="Đã phục vụ" Tag="Served"/>
                    <ComboBoxItem Content="Hoàn thành" Tag="Completed"/>
                    <ComboBoxItem Content="Đã hủy" Tag="Cancelled"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Orders Table -->
        <Border Grid.Row="2" Background="White" Margin="30,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            
            <DataGrid ItemsSource="{Binding Orders}" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Background="White"
                      BorderThickness="0"
                      RowHeight="60"
                      CanUserResizeRows="False"
                      SelectionMode="Single">
                
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F7FAFC"/>
                        <Setter Property="Foreground" Value="#4A5568"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="15,12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    </Style>
                    
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F7FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" 
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <!-- Order ID -->
                    <DataGridTextColumn Header="Mã Đơn" Binding="{Binding Id}" Width="0.8*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <!-- Table -->
                    <DataGridTextColumn Header="Bàn" Binding="{Binding TableName}" Width="1*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#2D3748"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <!-- Date Time -->
                    <DataGridTextColumn Header="Thời Gian" Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="1.5*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#718096"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <!-- Total Amount -->
                    <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TotalAmount, StringFormat={}{0:N0} đ}" Width="1.2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Foreground" Value="#10B981"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <!-- Status -->
                    <DataGridTemplateColumn Header="Trạng Thái" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="10,6" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#EDF2F7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Preparing">
                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Served">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="#E5E7EB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A5568"/>
                                                <Setter Property="Text" Value="{Binding Status}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                        <Setter Property="Text" Value="Chờ xử lý"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Preparing">
                                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                                        <Setter Property="Text" Value="Đang chuẩn bị"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Served">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                        <Setter Property="Text" Value="Đã phục vụ"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#6B7280"/>
                                                        <Setter Property="Text" Value="Hoàn thành"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                        <Setter Property="Text" Value="Đã hủy"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Thao Tác" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Xem chi tiết" 
                                        Background="#3B82F6"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="12,6"
                                        FontSize="12"
                                        Cursor="Hand"
                                        HorizontalAlignment="Center"
                                        MinWidth="100"
                                        Style="{StaticResource ModernButtonStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" 
              Background="#80FFFFFF" 
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Đang tải..." 
                           Foreground="#3B82F6" 
                           Margin="0,10,0,0" 
                           FontSize="16"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
