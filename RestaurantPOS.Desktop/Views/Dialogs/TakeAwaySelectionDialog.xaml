<UserControl x:Class="RestaurantPOS.Desktop.Views.Dialogs.TakeAwaySelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             mc:Ignorable="d" 
             Width="600" Height="500" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <fa:IconImage Icon="ShoppingBag" Foreground="White" Height="24" Width="24" Margin="0,0,15,0"/>
                    <TextBlock Text="Đơn hàng Mang về đang phục vụ" Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <Button Style="{StaticResource MaterialDesignIconForegroundButton}" 
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        HorizontalAlignment="Right" Foreground="White">
                    <fa:IconImage Icon="Times" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Chọn đơn hàng để tiếp tục phục vụ hoặc tạo đơn mới" Foreground="Gray" Margin="0,0,0,15"/>

            <!-- Loading Indicator -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True"/>
                <TextBlock Text="Đang tải danh sách đơn..." Margin="0,10,0,0" Foreground="Gray"/>
            </StackPanel>

            <!-- Order List with Animation -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" 
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource MaterialDesignScrollViewer}">
                        <Style.Triggers>
                            <Trigger Property="Visibility" Value="Visible">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                                            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.4" DecelerationRatio="0.9"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                
                <ItemsControl ItemsSource="{Binding ActiveOrders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,12" Height="Auto" HorizontalContentAlignment="Stretch" Padding="0"
                                    Command="{Binding DataContext.SelectOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" Background="Transparent" BorderBrush="Transparent">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="CardBorder" Background="White" CornerRadius="10" BorderBrush="#EEE" BorderThickness="1" Padding="15,12" UseLayoutRounding="True">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.1" Direction="270"/>
                                                        </Border.Effect>
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <Border.RenderTransformOrigin>
                                                            <Point X="0.5" Y="0.5"/>
                                                        </Border.RenderTransformOrigin>
                                                        
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CardBorder" Property="Background" Value="#FAFAFA"/>
                                                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                                            <Setter TargetName="CardBorder" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter TargetName="CardBorder" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="CardBorder" Property="Background" Value="#F0F0F0"/>
                                                            <Setter TargetName="CardBorder" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Background="#E1F5FE" CornerRadius="20" Width="40" Height="40" Margin="0,0,15,0">
                                        <fa:IconImage Icon="Receipt" Foreground="{DynamicResource PrimaryHueMidBrush}" Height="20" Width="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Id, StringFormat='Đơn hàng #{0}'}" FontWeight="Bold" FontSize="16" Foreground="#333"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <fa:IconImage Icon="Clock" Foreground="Gray" Height="12" Width="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding OrderDate, StringFormat='HH:mm dd/MM/yyyy'}" Foreground="Gray" FontSize="12"/>
                                            
                                            <fa:IconImage Icon="Utensils" Foreground="Gray" Height="12" Width="12" Margin="15,0,5,0"/>
                                            <TextBlock Text="{Binding OrderItems.Count, StringFormat='{}{0} món'}" Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Total -->
                                    <TextBlock Grid.Column="2" Text="{Binding TotalAmount, StringFormat='{}{0:N0} đ'}" 
                                               FontWeight="Bold" FontSize="16" Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <TextBlock Grid.Row="1" Text="Hiện không có đơn hàng nào đang phục vụ" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" FontStyle="Italic">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveOrders.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Actions -->
        <Border Grid.Row="2" Padding="20" BorderBrush="#EEE" BorderThickness="0,1,0,0">
            <Button Command="{Binding CreateNewOrderCommand}" 
                    Style="{StaticResource MaterialDesignRaisedButton}" Height="50"
                    materialDesign:ShadowAssist.ShadowDepth="Depth2"
                    materialDesign:ButtonAssist.CornerRadius="10" FontSize="16">
                <StackPanel Orientation="Horizontal">
                    <fa:IconImage Icon="Plus" Foreground="White" Height="16" Width="16" Margin="0,0,10,0"/>
                    <TextBlock Text="Tạo đơn mới"/>
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</UserControl>
