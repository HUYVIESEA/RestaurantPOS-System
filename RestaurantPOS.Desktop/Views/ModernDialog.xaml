<Window x:Class="RestaurantPOS.Desktop.Views.ModernDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialog" 
        Height="250" 
        Width="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#3B82F6" CornerRadius="10,10,0,0" Padding="20,15">
                <TextBlock x:Name="TitleText" 
                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="30,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <TextBlock x:Name="IconText" 
                           Grid.Column="0" 
                           FontSize="48" 
                           VerticalAlignment="Center" 
                           Margin="0,0,20,0"/>

                <!-- Message -->
                <TextBlock x:Name="MessageText" 
                           Grid.Column="1" 
                           Text="{Binding Message, RelativeSource={RelativeSource AncestorType=Window}}" 
                           TextWrapping="Wrap" 
                           VerticalAlignment="Center" 
                           FontSize="14"
                           LineHeight="22"/>
            </Grid>

            <!-- Footer Buttons -->
            <Border Grid.Row="2" BorderBrush="#F5F5F5" BorderThickness="0,1,0,0" Padding="20,15" Background="#FAFAFA" CornerRadius="0,0,10,10">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Buttons will be added dynamically in code-behind -->
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
