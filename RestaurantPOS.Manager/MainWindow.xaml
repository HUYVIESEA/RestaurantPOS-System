<Window x:Class="RestaurantPOS.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestaurantPOS.Manager"
        mc:Ignorable="d"
        Title="System Administration - Restaurant POS" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}"
        Icon="icons8-restaurant-94.ico"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Margin="10,0">
                            <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                <!-- You could add icons here later -->
                                <ContentPresenter/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <StackPanel>
                <!-- Branding -->
                <StackPanel Orientation="Horizontal" Margin="24,32,24,40">
                    <Border Background="{StaticResource PrimaryColor}" Width="40" Height="40" CornerRadius="8">
                         <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="4" ShadowDepth="2"/>
                        </Border.Effect>
                        <TextBlock Text="SA" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="System Admin" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextColor}"/>
                        <TextBlock Text="RestaurantPOS" FontSize="13" Foreground="{StaticResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <RadioButton x:Name="NavDashboard" Content="Overview Panel" Click="Nav_Click" Tag="Dashboard" IsChecked="True" Style="{StaticResource NavButtonStyle}"/>
                <RadioButton x:Name="NavServices" Content="Service Management" Click="Nav_Click" Tag="Services" Style="{StaticResource NavButtonStyle}"/>
                <RadioButton x:Name="NavDatabase" Content="Database Operations" Click="Nav_Click" Tag="Database" Style="{StaticResource NavButtonStyle}"/>
                <RadioButton x:Name="NavMaintenance" Content="System Maintenance" Click="Nav_Click" Tag="Maintenance" Style="{StaticResource NavButtonStyle}"/>
                
                <Rectangle Height="1" Fill="#E5E7EB" Margin="20,20"/>
                
                <!-- System Info (Sidebar Bot) -->
                <StackPanel Margin="24">
                     <TextBlock Text="System Resources" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SubTextColor}" Margin="0,0,0,10"/>
                     
                     <TextBlock Text="CPU Usage" FontSize="12" Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                     <ProgressBar x:Name="CpuProgressBar" Height="6" Background="#F3F4F6" BorderThickness="0" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,12"/>
                     
                     <TextBlock Text="RAM Usage" FontSize="12" Foreground="{StaticResource SubTextColor}" Margin="0,0,0,4"/>
                     <ProgressBar x:Name="RamProgressBar" Height="6" Background="#F3F4F6" BorderThickness="0" Foreground="{StaticResource WarningColor}"/>
                     <TextBlock x:Name="RamUsageText" Text="0%" HorizontalAlignment="Right" Margin="0,-16,0,0" FontSize="11" Foreground="{StaticResource SubTextColor}"/>

                     <TextBlock x:Name="ActiveProcessCount" Text="Active Processes: 0" Margin="0,20,0,0" FontSize="12" Foreground="{StaticResource SubTextColor}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Views -->
            <Grid Grid.Row="0" Margin="32">
                
                <!-- DASHBOARD VIEW -->
                <Grid x:Name="View_Dashboard">
                    <StackPanel>
                        <TextBlock Text="System Overview" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,24"/>
                        
                        <!-- Status Cards -->
                        <WrapPanel>
                            <!-- API Status -->
                            <Border Style="{StaticResource CardStyle}" Width="250" Margin="0,0,20,20">
                                <StackPanel>
                                    <TextBlock Text="Backend API" Foreground="{StaticResource SubTextColor}" FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Ellipse x:Name="ApiStatusIndicator" Width="12" Height="12" Fill="#EF4444" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="ApiStatusText" Text="Stopped" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                                    </StackPanel>
                                    <TextBlock Text="Port: 5000" FontSize="12" Foreground="{StaticResource SubTextColor}" Margin="22,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Web Status -->
                            <Border Style="{StaticResource CardStyle}" Width="250" Margin="0,0,20,20">
                                <StackPanel>
                                    <TextBlock Text="Web Client" Foreground="{StaticResource SubTextColor}" FontWeight="Medium"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Ellipse x:Name="WebStatusIndicator" Width="12" Height="12" Fill="#EF4444" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="WebStatusText" Text="Stopped" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                                    </StackPanel>
                                    <TextBlock Text="Port: 5173" FontSize="12" Foreground="{StaticResource SubTextColor}" Margin="22,4,0,0"/>
                                </StackPanel>
                            </Border>
                   
                        </WrapPanel>

                        <!-- Dashboard Actions -->
                        <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" Margin="0,10,0,15"/>
                        <WrapPanel>
                             <Button Content="Start All Services" Click="BtnStartDesktop_Click" Style="{StaticResource ModernButtonStyle}" Width="160" Background="{StaticResource PrimaryColor}"/>
                             <Button Content="Stop All Services" Click="BtnStopAll_Click" Style="{StaticResource ModernButtonStyle}" Width="160" Background="{StaticResource DangerColor}"/>
                             <Button Content="Open Web Client" Click="BtnStartWeb_Click" Style="{StaticResource OutlineButtonStyle}" Width="160"/>
                             <Button Content="Open Swagger API" Click="BtnSwagger_Click" Style="{StaticResource OutlineButtonStyle}" Width="160"/>
                        </WrapPanel>
                        
                        <!-- Cpu Text Hidden element for compatibility with CS code if needed, but we moved it to sidebar -->
                        <TextBlock x:Name="CpuUsageText" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

                <!-- SERVICES VIEW -->
                <Grid x:Name="View_Services" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Service Management" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,24"/>
                        
                        <!-- API Service -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Backend API Service" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Runs the core business logic and database connections. Required for all clients." Foreground="{StaticResource SubTextColor}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Start" Click="BtnStartApi_Click" Style="{StaticResource ModernButtonStyle}" Background="{StaticResource SuccessColor}" Width="100"/>
                                    <Button Content="Stop" Click="BtnStopApi_Click" Style="{StaticResource OutlineButtonStyle}" Width="100"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Web Service -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Web Client Service" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Hosts the web interface for staff and management. (Vite/React)" Foreground="{StaticResource SubTextColor}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Start" Click="BtnStartWeb_Click" Style="{StaticResource ModernButtonStyle}" Background="{StaticResource SuccessColor}" Width="100"/>
                                    <Button Content="Stop" Click="BtnStopWeb_Click" Style="{StaticResource OutlineButtonStyle}" Width="100"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Desktop App -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Desktop Application" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Launches the WPF Point of Sale interface." Foreground="{StaticResource SubTextColor}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Launch" Click="BtnStartDesktop_Click" Style="{StaticResource ModernButtonStyle}" Background="{StaticResource PrimaryColor}" Width="100"/>
                                    <Button Content="Kill" Click="BtnStopAll_Click" Style="{StaticResource OutlineButtonStyle}" Width="100"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- DATABASE VIEW -->
                <Grid x:Name="View_Database" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Database Operations" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,24"/>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Migration &amp; Seeding" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <WrapPanel>
                                    <Button Content="Update Schema (Migrate)" Click="BtnUpdateDb_Click" Style="{StaticResource ModernButtonStyle}" Width="220"/>
                                    <Button Content="Seed Default Data" Click="BtnSeedDb_Click" Style="{StaticResource OutlineButtonStyle}" Width="200"/>
                                </WrapPanel>
                                <TextBlock Text="Use 'Update Schema' to apply pending migrations. Use 'Seed Default Data' to populate initial menus and users." 
                                           Foreground="{StaticResource SubTextColor}" Margin="5,10,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Configuration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <Button Content="Edit AppSettings.json" Click="BtnEditConfig_Click" Style="{StaticResource OutlineButtonStyle}" HorizontalAlignment="Left" Width="220"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- MAINTENANCE VIEW -->
                <Grid x:Name="View_Maintenance" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="System Maintenance" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextColor}" Margin="0,0,0,24"/>

                        <Border Style="{StaticResource CardStyle}">
                             <StackPanel>
                                <TextBlock Text="Deployment &amp; Build" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <WrapPanel>
                                    <Button Content="Install Dependencies" Click="BtnInstallDeps_Click" Style="{StaticResource ModernButtonStyle}" Width="200"/>
                                    <Button Content="Build Production" Click="BtnBuildProd_Click" Style="{StaticResource OutlineButtonStyle}" Width="200"/>
                                </WrapPanel>
                             </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                             <StackPanel>
                                <TextBlock Text="Troubleshooting" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <WrapPanel>
                                    <Button Content="Clean Project (Deep Clean)" Click="BtnClean_Click" Style="{StaticResource OutlineButtonStyle}" Width="220" Foreground="{StaticResource DangerColor}" BorderBrush="{StaticResource DangerColor}"/>
                                    <Button Content="Setup Firewall Rules" Click="BtnFirewall_Click" Style="{StaticResource OutlineButtonStyle}" Width="200"/>
                                </WrapPanel>
                             </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- Logs Panel (Always Visible at bottom) -->
            <Border Grid.Row="1" Background="#111827" BorderBrush="#374151" BorderThickness="0,1,0,0" Height="200" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="System Activity Log" Foreground="#9CA3AF" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="NgrokStatusText" Visibility="Collapsed"/> <!-- Hidden compat -->
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtLogs" Foreground="#10B981" FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
