flowchart TD
    %% Define styles
    classDef process fill:#e1f5fe,stroke:#01579b,stroke-width:2px;
    classDef api fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;
    classDef db fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;

    %% ---------------------------------------------------------
    %% 1. AUTHENTICATION MODULE
    %% ---------------------------------------------------------
    subgraph Auth["Authentication Flow"]
        A_Start(Start) --> A_UI[Login Window]
        A_UI --> A_Input{Input Credentials}
        A_Input --> |Submit| A_Call[AuthService.LoginAsync]
        A_Call --> |POST /api/auth/login| A_API[AuthController]
        A_API --> |Valid?| A_DB[Check User Table]:::db
        A_DB --> |Result| A_API
        A_API --> |Token/Error| A_Call
        A_Call --> |Save Token| A_Session[UserSession]
        A_Session --> A_Redirect[Main Window]
    end

    %% ---------------------------------------------------------
    %% 2. TABLE MANAGEMENT MODULE
    %% ---------------------------------------------------------
    subgraph Table["Table Management Flow"]
        B_Start(View Tables) --> B_Call[TableService.GetTablesAsync]
        B_Call --> |GET /api/tables| B_API[TablesController]
        B_API --> |Query| B_DB[Tables Table]:::db
        B_API --> |Return List| B_UI[Table Map UI]
        
        B_UI --> |Select Table| B_Action{Action?}
        B_Action --> |Merge| B_Merge[TableService.MergeTables]
        B_Action --> |Split| B_Split[TableService.SplitTables]
        
        B_Merge --> |POST /merge| B_API
        B_Split --> |POST /split| B_API
        
        B_API --> |Success| B_SignalR[SignalR Broadcast]
        B_SignalR --> |Update UI| B_UI
    end

    %% ---------------------------------------------------------
    %% 3. ORDER MANAGEMENT MODULE
    %% ---------------------------------------------------------
    subgraph Order["Order Management Flow"]
        C_Start(Select Table) --> C_Check{Has Order?}
        C_Check --> |No| C_New[Create Order]
        C_Check --> |Yes| C_View[Load Order Details]
        
        C_New --> |Add Items| C_Cart[Local Cart]
        C_Cart --> |Submit| C_Call[OrderService.CreateOrderAsync]
        C_Call --> |POST /api/orders| C_API[OrdersController]
        
        C_View --> |Add Item| C_Add[OrderService.AddItem]
        C_Add --> |POST /orders/{id}/items| C_API
        
        C_View --> |Update Note| C_Note[OrderService.UpdateNote]
        C_Note --> |PATCH /items/note| C_API
        
        C_API --> |Save| C_DB[Orders/OrderItems Tables]:::db
        C_API --> |Notify Kitchen| C_SignalR[SignalR Broadcast]
    end

    %% ---------------------------------------------------------
    %% 4. PAYMENT MODULE
    %% ---------------------------------------------------------
    subgraph Pay["Payment Flow"]
        D_Start(Checkout) --> D_Calc[Calculate Total]
        D_Calc --> D_Method{Method?}
        
        D_Method --> |QR Code| D_QR[Get Bank Info]
        D_QR --> |GET /payment-settings| D_API_Set[PaymentSettingsController]
        D_API_Set --> |Return Info| D_Gen[Generate VietQR]
        D_Gen --> D_Show[Show QR Dialog]
        
        D_Method --> |Cash| D_Cash[Input Amount]
        
        D_Show --> D_Confirm[Confirm Payment]
        D_Cash --> D_Confirm
        
        D_Confirm --> |PUT /orders/complete| D_API[OrdersController]
        D_API --> |Update Status| D_DB[Orders/Payments Tables]:::db
        D_DB --> |Close Order| D_API
        D_API --> |Free Table| D_Free[TableService]
    end

    %% ---------------------------------------------------------
    %% 5. REPORTING MODULE
    %% ---------------------------------------------------------
    subgraph Report["Reporting Flow"]
        E_Start(View Reports) --> E_Filter[Select Date Range]
        E_Filter --> E_Call[ReportService.GetRevenue]
        E_Call --> |GET /api/reports| E_API[ReportController]
        E_API --> |Aggregate| E_DB[Orders/Payments Tables]:::db
        E_API --> |Return JSON| E_UI[Chart UI]
        
        E_UI --> |Click Export| E_Export[ReportExportService]
        E_Export --> |Generate Excel| E_File[Save .xlsx File]
    end
