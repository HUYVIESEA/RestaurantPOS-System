sequenceDiagram
    participant U as User
    participant UI as Main Window (Table Map)
    participant S as Table Service
    participant API as API Controller
    participant Hub as SignalR Hub
    participant DB as Database

    U->>UI: Select Floor (Tầng 1/2)
    UI->>S: GetTablesAsync()
    S->>API: GET /api/Tables
    API->>DB: Select * From Tables
    DB-->>API: Return List<Table>
    API-->>S: JSON Array
    S-->>UI: Update Table List
    
    loop Real-time Updates
        API->>Hub: Broadcast "TableUpdated"
        Hub-->>S: Trigger OnTableUpdated
        S-->>UI: Refresh Table Status
    end

    U->>UI: Click on Table T01
    alt Table is Empty
        UI->>UI: Open New Order Dialog
    else Table is Occupied
        UI->>UI: Open Order Details View
    end
